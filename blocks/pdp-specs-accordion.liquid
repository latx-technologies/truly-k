{% doc %}
  Renders a single specifications accordion item inside the PDP Specifications
  block. Used as the editor-managed fallback when a product has no
  `custom.spec_sections` metafield set.

  Each accordion has a heading and either rich-text content or a two-column
  key/value table.

  @example
  {% content_for 'block', type: 'pdp-specs-accordion', id: 'pdp-specs-accordion' %}
{% enddoc %}

<div
  class="pdp-specs__item{% if block.settings.open_by_default %} is-open{% endif %}"
  data-accordion
  {{ block.shopify_attributes }}
>
  {% render 'pdp-specs-accordion-item',
    heading: block.settings.heading,
    content_type: block.settings.content_type,
    text: block.settings.text,
    table_rows: block.settings.table_rows,
    open: block.settings.open_by_default
  %}
</div>

{% schema %}
{
  "name": "t:pdp.specs.accordion.name",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.heading",
      "default": "Specifications"
    },
    {
      "type": "checkbox",
      "id": "open_by_default",
      "label": "t:pdp.specs.accordion.open_by_default_label",
      "default": false
    },
    {
      "type": "select",
      "id": "content_type",
      "label": "t:pdp.specs.accordion.content_type_label",
      "default": "text",
      "options": [
        { "value": "text", "label": "t:pdp.specs.accordion.content_type_text" },
        { "value": "table", "label": "t:pdp.specs.accordion.content_type_table" }
      ]
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "t:labels.text",
      "visible_if": "{{ block.settings.content_type == 'text' }}",
      "default": "<p>Describe this section here.</p>"
    },
    {
      "type": "textarea",
      "id": "table_rows",
      "label": "t:pdp.specs.accordion.table_rows_label",
      "info": "t:pdp.specs.accordion.table_rows_info",
      "visible_if": "{{ block.settings.content_type == 'table' }}",
      "default": "Brand | MOOD\nSkin type | All skin types\nSize | 30 ml"
    }
  ],
  "presets": [{ "name": "t:pdp.specs.accordion.name" }]
}
{% endschema %}
