{% comment %}
  Used by templates/customers/addresses.json to render the customer's saved
  addresses with create, edit, and delete forms.
{% endcomment %}

<section
  class="account-dashboard"
  style="
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;
  "
>
  <div class="container">
    <header class="account-dashboard__header">
      <div class="account-dashboard__greeting">
        <span class="account-dashboard__eyebrow text-label">{{ 'customer.account.title' | t }}</span>
        <h1 class="account-dashboard__title heading-section-lg">
          {{ 'customer.account.addresses_title' | t }}
        </h1>
      </div>
    </header>

    <div class="account-dashboard__layout">
      <aside class="account-dashboard__sidebar">
        {% render 'account-nav', active: 'addresses' %}
      </aside>

      <div class="account-dashboard__main">

        <section class="account-panel">
          <header class="account-panel__header">
            <h2 class="account-panel__title heading-card">{{ 'customer.account.addresses.list_title' | t }}</h2>
            <button type="button" class="btn btn-secondary btn--sm" data-address-action="show-new">
              <span>{{ 'customer.account.addresses.add_new' | t }}</span>
            </button>
          </header>

          {%- comment -%} New address form (hidden by default) {%- endcomment -%}
          <div class="address-form" id="address-new" hidden>
            <h3 class="address-form__title heading-card">{{ 'customer.account.addresses.new_title' | t }}</h3>
            {%- form 'customer_address', customer.new_address -%}
              {%- if form.errors -%}
                <div class="form-error-list" role="alert">
                  {%- for field in form.errors -%}
                    <p class="form-error">{{ form.errors.translated_fields[field] | capitalize }} {{ form.errors.messages[field] }}</p>
                  {%- endfor -%}
                </div>
              {%- endif -%}

              {% render 'address-fields', form: form, prefix: 'new' %}

              <label class="form-checkbox">
                <input type="checkbox" name="address[default]" value="1">
                {{ 'customer.account.addresses.set_default' | t }}
              </label>

              <div class="address-form__actions">
                <button type="submit" class="btn btn-primary">
                  <span>{{ 'customer.account.addresses.save' | t }}</span>
                </button>
                <button type="button" class="btn btn-secondary" data-address-action="hide-new">
                  <span>{{ 'customer.account.addresses.cancel' | t }}</span>
                </button>
              </div>
            {%- endform -%}
          </div>

          {%- comment -%} Saved addresses {%- endcomment -%}
          {%- if customer.addresses.size > 0 -%}
            <div class="address-list">
              {%- paginate customer.addresses by 6 -%}
                {%- for address in customer.addresses -%}
                  <article class="address-card{% if address == customer.default_address %} address-card--default{% endif %}">
                    {%- if address == customer.default_address -%}
                      <span class="address-card__badge text-label">{{ 'customer.account.addresses.default' | t }}</span>
                    {%- endif -%}

                    <div class="address-card__body">
                      {{ address | format_address }}
                    </div>

                    <div class="address-card__actions">
                      <button type="button" class="address-card__btn" data-address-action="show-edit" data-address-id="{{ address.id }}">
                        {{ 'customer.account.addresses.edit' | t }}
                      </button>
                      {%- form 'customer_address', address -%}
                        <button
                          type="submit"
                          name="_method"
                          value="delete"
                          class="address-card__btn address-card__btn--danger"
                          data-confirm-delete="{{ 'customer.account.addresses.confirm_delete' | t | escape }}"
                        >
                          {{ 'customer.account.addresses.delete' | t }}
                        </button>
                      {%- endform -%}
                    </div>

                    <div class="address-form" id="address-edit-{{ address.id }}" hidden>
                      <h3 class="address-form__title heading-card">{{ 'customer.account.addresses.edit_title' | t }}</h3>
                      {%- form 'customer_address', address -%}
                        {%- if form.errors -%}
                          <div class="form-error-list" role="alert">
                            {%- for field in form.errors -%}
                              <p class="form-error">{{ form.errors.translated_fields[field] | capitalize }} {{ form.errors.messages[field] }}</p>
                            {%- endfor -%}
                          </div>
                        {%- endif -%}

                        {% render 'address-fields', form: form, prefix: address.id %}

                        <label class="form-checkbox">
                          <input type="checkbox" name="address[default]" value="1" {% if address == customer.default_address %}checked{% endif %}>
                          {{ 'customer.account.addresses.set_default' | t }}
                        </label>

                        <div class="address-form__actions">
                          <button type="submit" class="btn btn-primary">
                            <span>{{ 'customer.account.addresses.save' | t }}</span>
                          </button>
                          <button type="button" class="btn btn-secondary" data-address-action="hide-edit" data-address-id="{{ address.id }}">
                            <span>{{ 'customer.account.addresses.cancel' | t }}</span>
                          </button>
                        </div>
                      {%- endform -%}
                    </div>
                  </article>
                {%- endfor -%}

                {%- if paginate.pages > 1 -%}
                  <div class="address-list__pagination">{{ paginate | default_pagination }}</div>
                {%- endif -%}
              {%- endpaginate -%}
            </div>
          {%- else -%}
            <p class="account-panel__empty">{{ 'customer.account.addresses.empty' | t }}</p>
          {%- endif -%}
        </section>

      </div>
    </div>
  </div>
</section>

{% stylesheet %}
  .address-form {
    display: flex;
    flex-direction: column;
    gap: 20px;
    padding: 24px;
    background: var(--color-gray-100);
    margin-bottom: 24px;
  }

  .address-form[hidden] {
    display: none;
  }

  .address-form__title {
    margin: 0;
  }

  .address-form__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }

  .address-form__grid--full {
    grid-template-columns: 1fr;
  }

  .address-form__actions {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  .address-list {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 20px;
  }

  .address-card {
    display: flex;
    flex-direction: column;
    gap: 14px;
    padding: 24px;
    border: 1px solid var(--color-gray-200);
    background: var(--color-white);
  }

  .address-card--default {
    border-color: var(--color-black);
  }

  .address-card__badge {
    margin: 0;
  }

  .address-card__body {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    line-height: 1.6;
    color: var(--color-gray-700);
    flex: 1;
  }

  .address-card__actions {
    display: flex;
    gap: 16px;
    padding-top: 12px;
    border-top: 1px solid var(--color-gray-200);
  }

  .address-card__btn {
    background: none;
    border: none;
    padding: 0;
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-black);
    cursor: pointer;
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: color var(--transition-fast);
  }

  .address-card__btn:hover {
    color: var(--color-gray-600);
  }

  .address-card__btn--danger {
    color: var(--color-error);
  }

  .address-card__btn--danger:hover {
    color: var(--color-error);
    opacity: 0.7;
  }

  .address-list__pagination {
    grid-column: 1 / -1;
    padding-top: 16px;
    text-align: center;
  }

  @media (max-width: 540px) {
    .address-form__grid {
      grid-template-columns: 1fr;
    }
  }
{% endstylesheet %}

{% javascript %}
  (function () {
    function toggle(id, show) {
      var el = document.getElementById(id);
      if (!el) return;
      el.hidden = !show;
      if (show) {
        var first = el.querySelector('input, select');
        if (first) first.focus();
        el.scrollIntoView({ behavior: 'smooth', block: 'center' });
      }
    }

    document.addEventListener('click', function (e) {
      var btn = e.target.closest('[data-address-action]');
      if (!btn) return;
      var action = btn.dataset.addressAction;
      var id = btn.dataset.addressId;

      if (action === 'show-new') toggle('address-new', true);
      if (action === 'hide-new') toggle('address-new', false);
      if (action === 'show-edit') toggle('address-edit-' + id, true);
      if (action === 'hide-edit') toggle('address-edit-' + id, false);
    });

    document.addEventListener('click', function (e) {
      var btn = e.target.closest('[data-confirm-delete]');
      if (!btn) return;
      if (!window.confirm(btn.dataset.confirmDelete)) {
        e.preventDefault();
      }
    });
  })();
{% endjavascript %}

{% schema %}
{
  "name": "t:names.main_addresses",
  "settings": [
    {
      "type": "range",
      "id": "padding_top",
      "label": "t:carousel_settings.padding_top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "t:carousel_settings.padding_bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 64
    }
  ]
}
{% endschema %}
