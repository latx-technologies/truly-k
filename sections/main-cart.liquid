{% comment %}
  Renders the /cart page: line items, quantity controls, cart note (optional),
  order summary with checkout button, and optional trust badge blocks.
  Quantities update via AJAX (/cart/change.js); the section refreshes
  totals client-side without a full page reload.
{% endcomment %}

<section
  class="cart-page"
  data-cart-section
  data-i18n-items-label="{{ 'cart.items_word' | t | escape }}"
  data-i18n-confirm-remove="{{ 'cart.confirm_remove' | t | escape }}"
  style="
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;
  "
>
  <div class="container">
    <header class="cart-page__header">
      <h1 class="cart-page__title heading-section-lg">{{ 'cart.title' | t }}</h1>
      <p class="cart-page__count" data-cart-count>
        {{ cart.item_count }} {{ 'cart.items_word' | t }}
      </p>
    </header>

    {%- if cart.item_count > 0 -%}
      <form action="{{ routes.cart_url }}" method="post" novalidate class="cart-page__form" data-cart-form>
        <div class="cart-page__layout">

          <div class="cart-page__items">
            <div class="cart-items" role="table" aria-label="{{ 'cart.title' | t }}">
              <div class="cart-items__head" role="row">
                <span role="columnheader" class="cart-items__col cart-items__col--product">{{ 'cart.headers.product' | t }}</span>
                <span role="columnheader" class="cart-items__col cart-items__col--qty">{{ 'cart.headers.quantity' | t }}</span>
                <span role="columnheader" class="cart-items__col cart-items__col--total">{{ 'cart.headers.total' | t }}</span>
              </div>

              {%- for item in cart.items -%}
                <div class="cart-item" role="row" data-cart-item data-line-key="{{ item.key }}" data-line-index="{{ forloop.index }}">
                  <div class="cart-item__product" role="cell">
                    <a href="{{ item.url }}" class="cart-item__media">
                      {%- if item.image -%}
                        {{ item.image | image_url: width: 240 | image_tag:
                          loading: 'lazy',
                          widths: '120, 180, 240',
                          class: 'cart-item__img',
                          alt: item.image.alt | default: item.product.title
                        }}
                      {%- else -%}
                        <div class="cart-item__img cart-item__img--placeholder">
                          {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
                        </div>
                      {%- endif -%}
                    </a>

                    <div class="cart-item__info">
                      {%- if item.product.type != blank -%}
                        <span class="cart-item__type">{{ item.product.type }}</span>
                      {%- endif -%}
                      <a href="{{ item.url }}" class="cart-item__title">{{ item.product.title }}</a>

                      {%- unless item.product.has_only_default_variant -%}
                        <span class="cart-item__variant">{{ item.variant.title }}</span>
                      {%- endunless -%}

                      {%- if item.selling_plan_allocation -%}
                        <span class="cart-item__variant">{{ item.selling_plan_allocation.selling_plan.name }}</span>
                      {%- endif -%}

                      {%- if item.properties != blank -%}
                        <ul class="cart-item__properties">
                          {%- for property in item.properties -%}
                            {%- assign prop_name = property.first -%}
                            {%- assign prop_value = property.last -%}
                            {%- if prop_name == blank or prop_value == blank -%}{%- continue -%}{%- endif -%}
                            {%- assign prop_first_char = prop_name | slice: 0, 1 -%}
                            {%- if prop_first_char == '_' -%}{%- continue -%}{%- endif -%}
                            <li>
                              <span class="cart-item__property-name">{{ prop_name }}:</span>
                              {%- if prop_value contains '/uploads/' -%}
                                <a href="{{ prop_value }}" class="cart-item__property-link">{{ prop_value | split: '/' | last }}</a>
                              {%- else -%}
                                {{ prop_value }}
                              {%- endif -%}
                            </li>
                          {%- endfor -%}
                        </ul>
                      {%- endif -%}

                      {%- if item.line_level_discount_allocations.size > 0 -%}
                        <ul class="cart-item__discounts">
                          {%- for allocation in item.line_level_discount_allocations -%}
                            <li class="cart-item__discount">
                              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"></path><line x1="7" y1="7" x2="7.01" y2="7"></line></svg>
                              {{ allocation.discount_application.title }}
                              ({{ allocation.amount | money }})
                            </li>
                          {%- endfor -%}
                        </ul>
                      {%- endif -%}

                      <div class="cart-item__price-row">
                        {%- if item.original_price != item.final_price -%}
                          <span class="cart-item__unit cart-item__unit--sale">{{ item.final_price | money }}</span>
                          <span class="cart-item__unit-compare">{{ item.original_price | money }}</span>
                        {%- else -%}
                          <span class="cart-item__unit">{{ item.original_price | money }}</span>
                        {%- endif -%}
                      </div>

                      <button type="button" class="cart-item__remove" data-cart-remove aria-label="{{ 'cart.remove_aria' | t: title: item.product.title }}">
                        {{ 'cart.remove' | t }}
                      </button>
                    </div>
                  </div>

                  <div class="cart-item__qty" role="cell">
                    <div class="qty-stepper" data-qty-stepper>
                      <button type="button" class="qty-stepper__btn" data-qty-action="decrease" aria-label="{{ 'cart.qty_decrease' | t }}">−</button>
                      <input
                        type="number"
                        class="qty-stepper__input"
                        name="updates[{{ item.key }}]"
                        value="{{ item.quantity }}"
                        min="0"
                        aria-label="{{ 'cart.qty_label' | t: title: item.product.title }}"
                        data-cart-qty
                      >
                      <button type="button" class="qty-stepper__btn" data-qty-action="increase" aria-label="{{ 'cart.qty_increase' | t }}">+</button>
                    </div>
                  </div>

                  <div class="cart-item__total" role="cell">
                    {%- if item.original_line_price != item.final_line_price -%}
                      <span class="cart-item__total-value" data-line-total>{{ item.final_line_price | money }}</span>
                      <span class="cart-item__total-compare">{{ item.original_line_price | money }}</span>
                    {%- else -%}
                      <span class="cart-item__total-value" data-line-total>{{ item.final_line_price | money }}</span>
                    {%- endif -%}
                  </div>
                </div>
              {%- endfor -%}
            </div>

            {%- if section.settings.enable_note -%}
              <details class="cart-note" {% if cart.note != blank %}open{% endif %}>
                <summary class="cart-note__summary link-arrow">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg>
                  {{ 'cart.note_label' | t }}
                </summary>
                <textarea
                  class="form-field__textarea cart-note__input"
                  name="note"
                  placeholder="{{ 'cart.note_placeholder' | t }}"
                  data-cart-note
                >{{ cart.note }}</textarea>
              </details>
            {%- endif -%}

            <a href="{{ routes.all_products_collection_url }}" class="cart-page__continue link-arrow">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="15 18 9 12 15 6"></polyline></svg>
              {{ 'cart.continue_shopping' | t }}
            </a>
          </div>

          <aside class="cart-summary" aria-label="{{ 'cart.summary_label' | t }}">
            <div class="cart-summary__inner">
              <h2 class="cart-summary__title heading-card">{{ 'cart.summary_title' | t }}</h2>

              <dl class="cart-summary__lines">
                <div class="cart-summary__line">
                  <dt>{{ 'cart.subtotal' | t }}</dt>
                  <dd data-cart-subtotal>{{ cart.items_subtotal_price | money }}</dd>
                </div>

                {%- if cart.cart_level_discount_applications.size > 0 -%}
                  <div class="cart-summary__discounts" data-cart-discounts>
                    {%- for discount in cart.cart_level_discount_applications -%}
                      <div class="cart-summary__line cart-summary__line--discount">
                        <dt>
                          {{ 'cart.discount' | t }}
                          <span class="cart-summary__code">{{ discount.title }}</span>
                        </dt>
                        <dd>-{{ discount.total_allocated_amount | money }}</dd>
                      </div>
                    {%- endfor -%}
                  </div>
                {%- endif -%}

                <div class="cart-summary__line cart-summary__line--total">
                  <dt>{{ 'cart.total' | t }}</dt>
                  <dd data-cart-total>{{ cart.total_price | money }}</dd>
                </div>
              </dl>

              <p class="cart-summary__disclaimer">{{ 'cart.shipping_tax_note' | t }}</p>

              <button type="submit" name="checkout" class="btn btn-primary cart-summary__checkout">
                <span>{{ 'cart.checkout' | t }}</span>
              </button>

              {%- if section.blocks.size > 0 -%}
                <ul class="cart-summary__badges">
                  {%- for block in section.blocks -%}
                    {%- if block.type == 'trust_badge' and block.settings.label != blank -%}
                      <li class="cart-summary__badge" {{ block.shopify_attributes }}>
                        {%- case block.settings.icon -%}
                          {%- when 'shipping' -%}
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="1" y="3" width="15" height="13"></rect><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon><circle cx="5.5" cy="18.5" r="2.5"></circle><circle cx="18.5" cy="18.5" r="2.5"></circle></svg>
                          {%- when 'returns' -%}
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="1 4 1 10 7 10"></polyline><path d="M3.51 15a9 9 0 1 0 2.13-9.36L1 10"></path></svg>
                          {%- when 'secure' -%}
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
                          {%- when 'support' -%}
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg>
                          {%- else -%}
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"></polyline></svg>
                        {%- endcase -%}
                        <span>{{ block.settings.label }}</span>
                      </li>
                    {%- endif -%}
                  {%- endfor -%}
                </ul>
              {%- endif -%}
            </div>
          </aside>

        </div>
      </form>

    {%- else -%}
      <div class="cart-empty" data-cart-empty>
        <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="9" cy="21" r="1"></circle>
          <circle cx="20" cy="21" r="1"></circle>
          <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>
        </svg>
        <h2 class="cart-empty__title heading-section">{{ 'cart.empty_title' | t }}</h2>
        <p class="cart-empty__body text-muted">{{ 'cart.empty_body' | t }}</p>
        <a href="{{ routes.all_products_collection_url }}" class="btn btn-primary">
          <span>{{ 'cart.empty_cta' | t }}</span>
        </a>
      </div>
    {%- endif -%}
  </div>
</section>

{% stylesheet %}
  .cart-page {
    padding: var(--section-padding-top, 48px) 0 var(--section-padding-bottom, 96px);
  }

  .cart-page__header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
    padding-bottom: 24px;
    margin-bottom: 32px;
    border-bottom: 1px solid var(--color-gray-200);
  }

  .cart-page__title { margin: 0; }

  .cart-page__count {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-gray-500);
    margin: 0;
  }

  .cart-page__layout {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(320px, 380px);
    gap: 48px;
    align-items: start;
  }

  .cart-page__items {
    display: flex;
    flex-direction: column;
    gap: 32px;
    min-width: 0;
  }

  /* Items table */
  .cart-items {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
  }

  .cart-items__head {
    display: grid;
    grid-template-columns: 1fr 160px 120px;
    gap: 24px;
    padding: 0 0 12px;
    border-bottom: 1.5px solid var(--color-black);
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-gray-500);
  }

  .cart-items__col--qty { text-align: center; }
  .cart-items__col--total { text-align: right; }

  .cart-item {
    display: grid;
    grid-template-columns: 1fr 160px 120px;
    gap: 24px;
    align-items: start;
    padding: 24px 0;
    border-bottom: 1px solid var(--color-gray-200);
  }

  .cart-item[data-removing] {
    opacity: 0.4;
    pointer-events: none;
  }

  .cart-item__product {
    display: grid;
    grid-template-columns: 100px 1fr;
    gap: 20px;
    align-items: start;
  }

  .cart-item__media {
    display: block;
    width: 100px;
    height: 120px;
    overflow: hidden;
    background: var(--color-gray-100);
  }

  .cart-item__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .cart-item__img--placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .cart-item__img--placeholder svg { width: 60%; opacity: 0.18; }

  .cart-item__info {
    display: flex;
    flex-direction: column;
    gap: 6px;
    min-width: 0;
  }

  .cart-item__type {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-gray-500);
  }

  .cart-item__title {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 500;
    line-height: 1.3;
    color: var(--color-black);
    text-decoration: none;
  }

  .cart-item__title:hover { color: var(--color-gray-600); }

  .cart-item__variant {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--color-gray-500);
  }

  .cart-item__properties,
  .cart-item__discounts {
    list-style: none;
    margin: 4px 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 2px;
    font-family: var(--font-body);
    font-size: var(--text-xs);
    color: var(--color-gray-500);
  }

  .cart-item__property-name {
    font-weight: 600;
    color: var(--color-gray-700);
  }

  .cart-item__discount {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: var(--color-black);
    font-weight: 600;
  }

  .cart-item__price-row {
    display: inline-flex;
    align-items: baseline;
    gap: 10px;
    margin-top: 6px;
    font-family: var(--font-body);
  }

  .cart-item__unit {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-black);
  }

  .cart-item__unit-compare {
    font-size: var(--text-xs);
    color: var(--color-gray-400);
    text-decoration: line-through;
  }

  .cart-item__remove {
    align-self: flex-start;
    background: none;
    border: none;
    padding: 0;
    margin-top: 8px;
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-gray-500);
    cursor: pointer;
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: color var(--transition-fast);
  }

  .cart-item__remove:hover { color: var(--color-black); }

  .cart-item__total {
    text-align: right;
    font-family: var(--font-body);
    font-size: var(--text-base);
    font-weight: 600;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 2px;
  }

  .cart-item__total-compare {
    font-size: var(--text-xs);
    font-weight: 400;
    color: var(--color-gray-400);
    text-decoration: line-through;
  }

  /* Quantity stepper */
  .qty-stepper {
    display: inline-flex;
    align-items: stretch;
    border: 1.5px solid var(--color-gray-300);
    background: var(--color-white);
    height: 44px;
  }

  .qty-stepper__btn {
    width: 40px;
    border: none;
    background: var(--color-white);
    color: var(--color-black);
    font-size: var(--text-lg);
    font-weight: 600;
    cursor: pointer;
    transition: background var(--transition-fast), color var(--transition-fast);
  }

  .qty-stepper__btn:hover:not(:disabled) {
    background: var(--color-black);
    color: var(--color-white);
  }

  .qty-stepper__btn:disabled { opacity: 0.35; cursor: not-allowed; }

  .qty-stepper__input {
    width: 56px;
    border: none;
    border-left: 1.5px solid var(--color-gray-300);
    border-right: 1.5px solid var(--color-gray-300);
    padding: 0;
    text-align: center;
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-black);
    background: var(--color-white);
    -moz-appearance: textfield;
  }

  .qty-stepper__input::-webkit-outer-spin-button,
  .qty-stepper__input::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }

  .qty-stepper__input:focus { outline: none; }

  /* Note */
  .cart-note {
    padding-top: 8px;
  }

  .cart-note__summary {
    cursor: pointer;
    user-select: none;
    list-style: none;
  }

  .cart-note__summary::-webkit-details-marker { display: none; }

  .cart-note__input {
    margin-top: 12px;
    min-height: 100px;
  }

  .cart-page__continue {
    align-self: flex-start;
  }

  .cart-page__continue svg {
    transition: transform var(--transition-fast);
  }

  .cart-page__continue:hover svg { transform: translateX(-4px); }

  /* Summary */
  .cart-summary {
    position: sticky;
    top: 32px;
  }

  .cart-summary__inner {
    display: flex;
    flex-direction: column;
    gap: 20px;
    padding: 32px;
    background: var(--color-gray-100);
    border-top: 3px solid var(--color-black);
  }

  .cart-summary__title { margin: 0 0 4px; }

  .cart-summary__lines {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin: 0;
  }

  .cart-summary__line {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 16px;
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--color-gray-700);
    margin: 0;
  }

  .cart-summary__line dt,
  .cart-summary__line dd { margin: 0; }

  .cart-summary__line--discount {
    color: var(--color-black);
    font-weight: 600;
  }

  .cart-summary__code {
    display: inline-block;
    margin-left: 6px;
    font-size: var(--text-xs);
    font-weight: 400;
    color: var(--color-gray-500);
  }

  .cart-summary__line--total {
    padding-top: 16px;
    margin-top: 4px;
    border-top: 1px solid var(--color-gray-300);
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 500;
    color: var(--color-black);
  }

  .cart-summary__disclaimer {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    color: var(--color-gray-500);
    margin: 0;
  }

  .cart-summary__checkout {
    width: 100%;
  }

  .cart-summary__badges {
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin: 12px 0 0;
    padding: 16px 0 0;
    border-top: 1px solid var(--color-gray-300);
    list-style: none;
  }

  .cart-summary__badge {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-gray-700);
  }

  /* Empty state */
  .cart-empty {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    padding: 96px 24px;
    text-align: center;
    color: var(--color-gray-500);
  }

  .cart-empty svg { color: var(--color-gray-300); }
  .cart-empty__title { margin: 8px 0 0; color: var(--color-black); }
  .cart-empty__body { margin: 0 0 16px; max-width: 420px; }

  @media (max-width: 1024px) {
    .cart-page__layout {
      grid-template-columns: minmax(0, 1fr) minmax(280px, 320px);
      gap: 32px;
    }
  }

  @media (max-width: 900px) {
    .cart-page__layout {
      grid-template-columns: 1fr;
      gap: 32px;
    }
    .cart-summary { position: static; }
  }

  @media (max-width: 768px) {
    .cart-page { padding: 32px 0 64px; }
    .cart-items__head { display: none; }
    .cart-item {
      grid-template-columns: 1fr;
      gap: 16px;
      padding: 20px 0;
    }
    .cart-item__qty { justify-self: start; }
    .cart-item__total { text-align: left; align-items: flex-start; }
    .cart-item__product {
      grid-template-columns: 80px 1fr;
      gap: 16px;
    }
    .cart-item__media { width: 80px; height: 96px; }
    .cart-summary__inner { padding: 24px; }
    .cart-empty { padding: 64px 16px; }
  }
{% endstylesheet %}

{% javascript %}
  (function () {
    var section = document.querySelector('[data-cart-section]');
    if (!section) return;

    var form = section.querySelector('[data-cart-form]');
    if (!form) return;

    var confirmRemove = section.dataset.i18nConfirmRemove || 'Remove this item?';
    var itemsLabel = section.dataset.i18nItemsLabel || 'items';

    var debounceTimers = {};

    function setItemBusy(row, busy) {
      if (busy) row.setAttribute('data-removing', '');
      else row.removeAttribute('data-removing');
    }

    function changeLine(key, quantity, row) {
      setItemBusy(row, true);
      return fetch('/cart/change.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
        body: JSON.stringify({ id: key, quantity: quantity })
      })
        .then(function (res) {
          if (!res.ok) throw new Error('Cart update failed');
          return res.json();
        })
        .then(function (cart) {
          // If quantity dropped to 0 or this line no longer exists, reload to re-render line state cleanly.
          var stillExists = (cart.items || []).some(function (i) { return i.key === key; });
          if (!stillExists) {
            window.location.reload();
            return;
          }
          updateCartUI(cart, row, key);
          setItemBusy(row, false);
        })
        .catch(function () {
          setItemBusy(row, false);
          window.location.reload();
        });
    }

    function updateCartUI(cart, row, key) {
      var subtotalEl = section.querySelector('[data-cart-subtotal]');
      var totalEl = section.querySelector('[data-cart-total]');
      var countEl = section.querySelector('[data-cart-count]');

      if (subtotalEl) subtotalEl.textContent = formatMoney(cart.items_subtotal_price);
      if (totalEl) totalEl.textContent = formatMoney(cart.total_price);
      if (countEl) countEl.textContent = cart.item_count + ' ' + itemsLabel;

      var item = (cart.items || []).find(function (i) { return i.key === key; });
      if (item && row) {
        var lineTotalEl = row.querySelector('[data-line-total]');
        if (lineTotalEl) lineTotalEl.textContent = formatMoney(item.final_line_price);
        var qtyInput = row.querySelector('[data-cart-qty]');
        if (qtyInput && parseInt(qtyInput.value, 10) !== item.quantity) {
          qtyInput.value = item.quantity;
        }
      }
    }

    function formatMoney(cents) {
      var amount = (cents / 100).toFixed(2);
      return '$' + amount.replace(/\B(?=(\d{3})+(?!\d))/g, ',');
    }

    section.addEventListener('click', function (e) {
      var stepBtn = e.target.closest('[data-qty-action]');
      if (stepBtn) {
        var row = stepBtn.closest('[data-cart-item]');
        var input = row.querySelector('[data-cart-qty]');
        var current = parseInt(input.value, 10) || 0;
        var next = stepBtn.dataset.qtyAction === 'increase' ? current + 1 : Math.max(0, current - 1);
        input.value = next;
        queueChange(row, input);
        return;
      }

      var removeBtn = e.target.closest('[data-cart-remove]');
      if (removeBtn) {
        if (!window.confirm(confirmRemove)) return;
        var row = removeBtn.closest('[data-cart-item]');
        var key = row.dataset.lineKey;
        changeLine(key, 0, row).then(function () {
          window.location.reload();
        });
      }
    });

    section.addEventListener('input', function (e) {
      var input = e.target.closest('[data-cart-qty]');
      if (!input) return;
      var row = input.closest('[data-cart-item]');
      queueChange(row, input);
    });

    function queueChange(row, input) {
      var key = row.dataset.lineKey;
      clearTimeout(debounceTimers[key]);
      debounceTimers[key] = setTimeout(function () {
        var qty = Math.max(0, parseInt(input.value, 10) || 0);
        changeLine(key, qty, row);
      }, 450);
    }

    // Save cart note without blocking the user
    var noteInput = section.querySelector('[data-cart-note]');
    if (noteInput) {
      var noteTimer;
      noteInput.addEventListener('input', function () {
        clearTimeout(noteTimer);
        noteTimer = setTimeout(function () {
          fetch('/cart/update.js', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ note: noteInput.value })
          });
        }, 600);
      });
    }
  })();
{% endjavascript %}

