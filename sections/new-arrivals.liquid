{%- assign collection = section.settings.collection -%}
{%- assign limit = section.settings.products_to_show | default: 12 -%}

{%- assign cart_product_ids = cart.items | map: 'product_id' | join: ',' -%}

<section
  class="new-arrivals"
  data-i18n-add-to-cart="{{ 'new_arrivals.add_to_cart' | t | escape }}"
  data-i18n-go-to-cart="{{ 'new_arrivals.go_to_cart' | t | escape }}"
  data-i18n-adding="{{ 'new_arrivals.adding' | t | escape }}"
  data-i18n-added="{{ 'new_arrivals.added' | t | escape }}"
  data-i18n-buy-it-now="{{ 'new_arrivals.buy_it_now' | t | escape }}"
  data-i18n-redirecting="{{ 'new_arrivals.redirecting' | t | escape }}"
  data-i18n-sold-out="{{ 'new_arrivals.sold_out' | t | escape }}"
>
  <div class="container">

    <div class="new-arrivals__header">
      <div class="new-arrivals__header-left">
        {%- if section.settings.heading != blank -%}
          <h2 class="new-arrivals__heading heading-section">{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.description != blank -%}
          <p class="new-arrivals__description">{{ section.settings.description }}</p>
        {%- endif -%}
      </div>
      {%- if section.settings.view_all_label != blank and collection != blank -%}
        <a href="{{ collection.url }}" class="new-arrivals__shop-all link-arrow">
          {{ section.settings.view_all_label }}
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
        </a>
      {%- endif -%}
    </div>

    <div class="new-arrivals__main">

      {%- if section.settings.promo_image != blank or section.settings.promo_heading != blank -%}
        <div class="new-arrivals__promo">
          {%- if section.settings.promo_image != blank -%}
            {{ section.settings.promo_image | image_url: width: 600 | image_tag:
              loading: 'lazy',
              widths: '300, 400, 600',
              class: 'new-arrivals__promo-bg'
            }}
          {%- endif -%}
          <div class="new-arrivals__promo-overlay"></div>
          <div class="new-arrivals__promo-content">
            {%- if section.settings.promo_subtitle != blank -%}
              <span class="new-arrivals__promo-subtitle">{{ section.settings.promo_subtitle }}</span>
            {%- endif -%}
            {%- if section.settings.promo_heading != blank -%}
              <h3 class="new-arrivals__promo-heading">{{ section.settings.promo_heading }}</h3>
            {%- endif -%}
            {%- if section.settings.promo_button_label != blank -%}
              <a href="{{ section.settings.promo_button_link | default: collection.url }}" class="new-arrivals__promo-link link-arrow">
                {{ section.settings.promo_button_label }}
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
              </a>
            {%- endif -%}
          </div>
        </div>
      {%- endif -%}

      <div class="new-arrivals__track-wrapper">
        <div class="new-arrivals__track">

          {%- if collection != blank -%}
            {%- for product in collection.products limit: limit -%}
              {%- assign has_discount = false -%}
              {%- if product.compare_at_price > product.price -%}
                {%- assign has_discount = true -%}
              {%- endif -%}

              {%- assign in_cart = false -%}
              {%- if cart_product_ids contains product.id -%}
                {%- assign in_cart = true -%}
              {%- endif -%}

              <div class="na-card" data-product-id="{{ product.id }}" data-variant-id="{{ product.selected_or_first_available_variant.id }}" data-in-cart="{{ in_cart }}">
                <div class="na-card__media">
                  <a href="{{ product.url }}" class="na-card__image-link">
                    {%- if product.featured_image -%}
                      {%- if forloop.first -%}
                        {{ product.featured_image | image_url: width: 600 | image_tag:
                          loading: 'eager',
                          widths: '300, 400, 600',
                          sizes: '(max-width: 768px) 50vw, 280px',
                          class: 'na-card__img'
                        }}
                      {%- else -%}
                        {{ product.featured_image | image_url: width: 600 | image_tag:
                          loading: 'lazy',
                          widths: '300, 400, 600',
                          sizes: '(max-width: 768px) 50vw, 280px',
                          class: 'na-card__img'
                        }}
                      {%- endif -%}
                    {%- else -%}
                      <div class="na-card__placeholder">
                        {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
                      </div>
                    {%- endif -%}
                  </a>

                  {%- if has_discount -%}
                    {%- assign discount_pct = product.compare_at_price | minus: product.price | times: 100.0 | divided_by: product.compare_at_price | round -%}
                    <span class="na-card__badge">-{{ discount_pct }}%</span>
                  {%- endif -%}

                  <div class="na-card__overlay">
                    {%- if in_cart -%}
                      <a href="{{ routes.cart_url }}" class="na-card__cart-btn na-card__cart-btn--go">
                        <span>{{ 'new_arrivals.go_to_cart' | t }}</span>
                      </a>
                    {%- else -%}
                      <button type="button" class="na-card__cart-btn na-card__cart-btn--add" data-variant-id="{{ product.selected_or_first_available_variant.id }}">
                        <span>{{ 'new_arrivals.add_to_cart' | t }}</span>
                      </button>
                    {%- endif -%}
                  </div>

                  <button type="button" class="na-card__zoom" aria-label="{{ 'new_arrivals.quick_view' | t: title: product.title }}" data-product-handle="{{ product.handle }}">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                      <circle cx="11" cy="11" r="8"></circle>
                      <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
                      <line x1="11" y1="8" x2="11" y2="14"></line>
                      <line x1="8" y1="11" x2="14" y2="11"></line>
                    </svg>
                  </button>
                </div>

                <div class="na-card__info">
                  {%- if product.type != blank -%}
                    <span class="na-card__type">{{ product.type }}</span>
                  {%- endif -%}
                  <a href="{{ product.url }}" class="na-card__title">{{ product.title }}</a>
                  <div class="na-card__prices">
                    <span class="na-card__price">{{ product.price | money }}</span>
                    {%- if has_discount -%}
                      <span class="na-card__compare-price">{{ product.compare_at_price | money }}</span>
                    {%- endif -%}
                  </div>
                </div>
              </div>

            {%- endfor -%}
          {%- else -%}
            {%- for i in (1..6) -%}
              <div class="na-card na-card--placeholder">
                <div class="na-card__media">
                  <div class="na-card__placeholder">
                    {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
                  </div>
                </div>
                <div class="na-card__info">
                  <span class="na-card__type">Category</span>
                  <span class="na-card__title">Product Title</span>
                  <div class="na-card__prices">
                    <span class="na-card__price">{{ 2999 | money }}</span>
                  </div>
                </div>
              </div>
            {%- endfor -%}
          {%- endif -%}

        </div>
      </div>
    </div>

    <div class="new-arrivals__footer">
      <div class="new-arrivals__progress">
        <div class="new-arrivals__progress-bar"></div>
      </div>
      <div class="new-arrivals__arrows">
        <button class="new-arrivals__arrow new-arrivals__arrow--prev" aria-label="{{ 'carousel.previous' | t }}">
          {{ 'icon-chevron-left.svg' | inline_asset_content }}
        </button>
        <button class="new-arrivals__arrow new-arrivals__arrow--next" aria-label="{{ 'carousel.next' | t }}">
          {{ 'icon-chevron-right.svg' | inline_asset_content }}
        </button>
      </div>
    </div>

  </div>

<div class="qv-modal" data-qv-modal aria-hidden="true">
  <div class="qv-modal__backdrop"></div>
  <div class="qv-modal__dialog" role="dialog" aria-label="{{ 'pdp.specs.title' | t | default: 'Quick view' }}">
    <button class="qv-modal__close" aria-label="{{ 'new_arrivals.close' | t }}">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <line x1="18" y1="6" x2="6" y2="18"></line>
        <line x1="6" y1="6" x2="18" y2="18"></line>
      </svg>
    </button>
    <div class="qv-modal__body">
      <div class="qv-modal__image">
        <img src="" alt="" class="qv-modal__img">
      </div>
      <div class="qv-modal__content">
        <h3 class="qv-modal__title"></h3>
        <div class="qv-modal__prices">
          <span class="qv-modal__price"></span>
          <span class="qv-modal__compare-price"></span>
        </div>
        <p class="qv-modal__description"></p>
        <div class="qv-modal__variants" style="display:none;">
          <span class="qv-modal__variants-label">{{ 'new_arrivals.size_label' | t }}: <strong class="qv-modal__variants-selected"></strong></span>
          <div class="qv-modal__variants-options"></div>
        </div>
        <div class="qv-modal__cart-row">
          <div class="qv-modal__qty">
            <button type="button" class="qv-modal__qty-btn" data-action="minus" aria-label="{{ 'new_arrivals.decrease' | t }}">−</button>
            <input type="number" class="qv-modal__qty-input" value="1" min="1" max="99" aria-label="{{ 'new_arrivals.quantity' | t }}">
            <button type="button" class="qv-modal__qty-btn" data-action="plus" aria-label="{{ 'new_arrivals.increase' | t }}">+</button>
          </div>
          <button type="button" class="qv-modal__add-btn">
            <span>{{ 'new_arrivals.add_to_cart' | t }}</span>
          </button>
        </div>
        <button type="button" class="qv-modal__buy-now btn btn-primary">
          <span>{{ 'new_arrivals.buy_it_now' | t }}</span>
        </button>
        <a href="#" class="qv-modal__details-link">
          {{ 'new_arrivals.view_full_details' | t }}
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
        </a>
      </div>
    </div>
  </div>
</div>
</section>

{% javascript %}
(function () {
  document.querySelectorAll('.new-arrivals').forEach(initNewArrivals);

  function initNewArrivals(section) {
  if (section.dataset.naInit === '1') return;
  section.dataset.naInit = '1';
  var modal = section.querySelector('[data-qv-modal]');
  if (!modal) return;

  var i18n = {
    addToCart: section.dataset.i18nAddToCart || 'Add to Cart',
    goToCart: section.dataset.i18nGoToCart || 'Go to Cart',
    adding: section.dataset.i18nAdding || 'Adding...',
    added: section.dataset.i18nAdded || 'Added',
    buyItNow: section.dataset.i18nBuyItNow || 'Buy It Now',
    redirecting: section.dataset.i18nRedirecting || 'Redirecting...',
    soldOut: section.dataset.i18nSoldOut || 'Sold Out'
  };

  var track = section.querySelector('.new-arrivals__track');
  var prevBtn = section.querySelector('.new-arrivals__arrow--prev');
  var nextBtn = section.querySelector('.new-arrivals__arrow--next');
  var progressBar = section.querySelector('.new-arrivals__progress-bar');

  function getScrollAmount() {
    var card = track.querySelector('.na-card');
    if (!card) return 300;
    var gap = parseInt(getComputedStyle(track).gap) || 20;
    return (card.offsetWidth + gap) * 2;
  }

  function updateControls() {
    var sl = track.scrollLeft;
    var max = track.scrollWidth - track.clientWidth;

    prevBtn.disabled = sl <= 4;
    nextBtn.disabled = sl >= max - 4;

    if (max > 0 && progressBar) {
      var pct = (sl / max) * 100;
      progressBar.style.width = Math.max(10, Math.min(100, pct)) + '%';
    }
  }

  prevBtn.addEventListener('click', function () {
    track.scrollBy({ left: -getScrollAmount(), behavior: 'smooth' });
  });
  nextBtn.addEventListener('click', function () {
    track.scrollBy({ left: getScrollAmount(), behavior: 'smooth' });
  });
  track.addEventListener('scroll', updateControls, { passive: true });
  updateControls();
  window.addEventListener('resize', updateControls);

  section.querySelectorAll('.na-card__cart-btn--add').forEach(function (btn) {
    btn.addEventListener('click', function (e) {
      e.preventDefault();
      var variantId = this.getAttribute('data-variant-id');
      var card = this.closest('.na-card');
      var btnEl = this;
      btnEl.querySelector('span').textContent = i18n.adding;
      btnEl.disabled = true;

      fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ items: [{ id: parseInt(variantId), quantity: 1 }] })
      })
      .then(function (r) { return r.json(); })
      .then(function () {
        card.setAttribute('data-in-cart', 'true');
        var overlay = card.querySelector('.na-card__overlay');
        overlay.innerHTML = '<a href="/cart" class="na-card__cart-btn na-card__cart-btn--go"><span>' + i18n.goToCart + '</span></a>';
      })
      .catch(function () {
        btnEl.querySelector('span').textContent = i18n.addToCart;
        btnEl.disabled = false;
      });
    });
  });

  /* ── Quick View Modal ── */
  var modalImg = modal.querySelector('.qv-modal__img');
  var modalTitle = modal.querySelector('.qv-modal__title');
  var modalPrice = modal.querySelector('.qv-modal__price');
  var modalCompare = modal.querySelector('.qv-modal__compare-price');
  var modalDesc = modal.querySelector('.qv-modal__description');
  var modalQtyInput = modal.querySelector('.qv-modal__qty-input');
  var modalAddBtn = modal.querySelector('.qv-modal__add-btn');
  var modalBuyBtn = modal.querySelector('.qv-modal__buy-now');
  var modalDetailsLink = modal.querySelector('.qv-modal__details-link');
  var modalVariantsWrap = modal.querySelector('.qv-modal__variants');
  var modalVariantsOptions = modal.querySelector('.qv-modal__variants-options');
  var modalVariantsSelected = modal.querySelector('.qv-modal__variants-selected');
  var currentVariantId = null;
  var currentProductData = null;

  function formatMoney(cents) {
    var curr = (Shopify.currency && Shopify.currency.active) ? Shopify.currency.active : 'INR';
    return new Intl.NumberFormat(Shopify.locale || 'en', {
      style: 'currency', currency: curr
    }).format(cents / 100);
  }

  function updateModalPrices(variant) {
    modalPrice.textContent = formatMoney(variant.price);
    if (variant.compare_at_price && variant.compare_at_price > variant.price) {
      modalCompare.textContent = formatMoney(variant.compare_at_price);
      modalCompare.style.display = '';
    } else {
      modalCompare.textContent = '';
      modalCompare.style.display = 'none';
    }
  }

  function selectVariant(variantId) {
    if (!currentProductData) return;
    var variant = currentProductData.variants.find(function (v) { return v.id === variantId; });
    if (!variant) return;
    currentVariantId = variant.id;
    updateModalPrices(variant);
    if (variant.title && variant.title !== 'Default Title') {
      modalVariantsSelected.textContent = variant.title;
    }
    modalVariantsOptions.querySelectorAll('.qv-modal__variant-btn').forEach(function (btn) {
      btn.classList.toggle('is-active', parseInt(btn.getAttribute('data-variant-id')) === variantId);
    });
    if (variant.featured_image) {
      modalImg.src = variant.featured_image.src.replace(/(\.\w+)$/, '_600x$1');
    }
    if (!variant.available) {
      modalAddBtn.disabled = true;
      modalAddBtn.querySelector('span').textContent = i18n.soldOut;
      modalBuyBtn.disabled = true;
      modalBuyBtn.querySelector('span').textContent = i18n.soldOut;
    } else {
      modalAddBtn.disabled = false;
      modalAddBtn.querySelector('span').textContent = i18n.addToCart;
      modalBuyBtn.disabled = false;
      modalBuyBtn.querySelector('span').textContent = i18n.buyItNow;
    }
  }

  section.querySelectorAll('.na-card__zoom').forEach(function (btn) {
    btn.addEventListener('click', function (e) {
      e.preventDefault();
      var handle = this.getAttribute('data-product-handle');
      modalQtyInput.value = 1;
      modalAddBtn.querySelector('span').textContent = i18n.addToCart;
      modalAddBtn.disabled = false;
      modalBuyBtn.querySelector('span').textContent = i18n.buyItNow;
      modalBuyBtn.disabled = false;
      fetch('/products/' + handle + '.js')
        .then(function (r) { return r.json(); })
        .then(function (product) {
          currentProductData = product;
          var variant = product.variants[0];
          currentVariantId = variant.id;
          modalImg.src = product.featured_image ? product.featured_image.replace(/(\.\w+)$/, '_600x$1') : '';
          modalImg.alt = product.title;
          modalTitle.textContent = product.title;
          updateModalPrices(variant);
          modalDesc.textContent = product.description
            ? product.description.replace(/<[^>]*>/g, '').substring(0, 200) + (product.description.length > 200 ? '...' : '')
            : '';
          modalDetailsLink.href = '/products/' + handle;
          if (product.variants.length > 1 && !(product.variants.length === 1 && product.variants[0].title === 'Default Title')) {
            modalVariantsWrap.style.display = '';
            modalVariantsOptions.innerHTML = '';
            var optionName = product.options[0] || 'Size';
            modalVariantsWrap.querySelector('.qv-modal__variants-label').innerHTML =
              optionName + ': <strong class="qv-modal__variants-selected">' + variant.title + '</strong>';
            modalVariantsSelected = modalVariantsWrap.querySelector('.qv-modal__variants-selected');
            product.variants.forEach(function (v) {
              var vBtn = document.createElement('button');
              vBtn.type = 'button';
              vBtn.className = 'qv-modal__variant-btn' + (v.id === variant.id ? ' is-active' : '');
              if (!v.available) vBtn.className += ' is-soldout';
              vBtn.setAttribute('data-variant-id', v.id);
              vBtn.textContent = v.title;
              vBtn.addEventListener('click', function () {
                selectVariant(parseInt(this.getAttribute('data-variant-id')));
              });
              modalVariantsOptions.appendChild(vBtn);
            });
          } else {
            modalVariantsWrap.style.display = 'none';
          }
          modal.setAttribute('aria-hidden', 'false');
          document.body.style.overflow = 'hidden';
        });
    });
  });

  function closeModal() {
    modal.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
    currentProductData = null;
  }
  modal.querySelector('.qv-modal__close').addEventListener('click', closeModal);
  modal.querySelector('.qv-modal__backdrop').addEventListener('click', closeModal);
  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape' && modal.getAttribute('aria-hidden') === 'false') closeModal();
  });

  modal.querySelectorAll('.qv-modal__qty-btn').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var val = parseInt(modalQtyInput.value) || 1;
      if (this.getAttribute('data-action') === 'minus') {
        modalQtyInput.value = Math.max(1, val - 1);
      } else {
        modalQtyInput.value = Math.min(99, val + 1);
      }
    });
  });

  modalAddBtn.addEventListener('click', function () {
    if (!currentVariantId) return;
    var qty = parseInt(modalQtyInput.value) || 1;
    var btnSpan = this.querySelector('span');
    btnSpan.textContent = i18n.adding;
    this.disabled = true;
    fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ items: [{ id: currentVariantId, quantity: qty }] })
    })
    .then(function (r) { return r.json(); })
    .then(function () {
      btnSpan.textContent = i18n.added;
      setTimeout(function () { closeModal(); }, 800);
      var card = section.querySelector('[data-variant-id="' + currentVariantId + '"]');
      if (card) {
        card.setAttribute('data-in-cart', 'true');
        var overlay = card.querySelector('.na-card__overlay');
        if (overlay) overlay.innerHTML = '<a href="/cart" class="na-card__cart-btn na-card__cart-btn--go"><span>' + i18n.goToCart + '</span></a>';
      }
    })
    .catch(function () { btnSpan.textContent = i18n.addToCart; modalAddBtn.disabled = false; });
  });

  modalBuyBtn.addEventListener('click', function () {
    if (!currentVariantId) return;
    var qty = parseInt(modalQtyInput.value) || 1;
    var btnSpan = this.querySelector('span');
    btnSpan.textContent = i18n.redirecting;
    this.disabled = true;
    fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ items: [{ id: currentVariantId, quantity: qty }] })
    })
    .then(function () { window.location.href = '/checkout'; })
    .catch(function () { btnSpan.textContent = i18n.buyItNow; modalBuyBtn.disabled = false; });
  });
  }
})();
{% endjavascript %}

{% stylesheet %}
.new-arrivals { padding: 80px 0; }
.new-arrivals__header { display: flex; align-items: end; justify-content: space-between; gap: 24px; margin-bottom: 32px; }
.new-arrivals__header-left { max-width: 480px; }
.new-arrivals__heading { margin: 0 0 6px; }
.new-arrivals__description { font-family: var(--font-body); font-size: var(--text-sm); color: var(--color-gray-500); line-height: 1.6; margin: 0; }
.new-arrivals__shop-all { flex-shrink: 0; margin-top: 4px; }
.new-arrivals__main { display: flex; gap: 20px; }
.new-arrivals__promo {
  flex: 0 0 260px;
  position: relative;
  overflow: hidden;
  background: var(--color-black);
  display: flex;
  align-items: flex-end;
  border-radius: 0;
}
.new-arrivals__promo-bg { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; display: block; }
.new-arrivals__promo-overlay { position: absolute; inset: 0; background: linear-gradient(to top, rgba(0,0,0,0.7) 30%, rgba(0,0,0,0.1) 100%); }
.new-arrivals__promo-content { position: relative; z-index: 1; padding: 28px 24px; display: flex; flex-direction: column; gap: 8px; }
.new-arrivals__promo-subtitle { font-family: var(--font-display); font-size: var(--text-base); font-style: italic; color: var(--color-gray-300); }
.new-arrivals__promo-heading { font-family: var(--font-display); font-size: var(--text-2xl); font-weight: 500; color: var(--color-white); line-height: 1.15; }
.new-arrivals__promo-link { color: var(--color-white); margin-top: 8px; }
.new-arrivals__promo-link:hover { color: var(--color-gray-300); }
.new-arrivals__track-wrapper { flex: 1; min-width: 0; overflow: hidden; }
.new-arrivals__track {
  display: flex;
  gap: 20px;
  overflow-x: auto;
  scroll-snap-type: x mandatory;
  -webkit-overflow-scrolling: touch;
  scrollbar-width: none;
  padding: 4px 8px 4px 0;
}
.new-arrivals__track::-webkit-scrollbar { display: none; }
.new-arrivals__footer { display: flex; align-items: center; justify-content: space-between; margin-top: 32px; gap: 20px; }
.new-arrivals__progress { flex: 1; width: 100%; height: 3px; background: var(--color-gray-200); }
.new-arrivals__progress-bar { height: 100%; width: 10%; background: var(--color-black); transition: width 0.15s ease; }
.new-arrivals__arrows { display: flex; gap: 4px; }
.new-arrivals__arrow {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 44px;
  height: 44px;
  border: 1.5px solid var(--color-gray-200);
  border-radius: 50%;
  background: var(--color-white);
  color: var(--color-black);
  cursor: pointer;
  transition: background var(--transition-fast),
              color var(--transition-fast),
              border-color var(--transition-fast);
  padding: 0;
}
.new-arrivals__arrow:hover:not(:disabled) { background: var(--color-black); color: var(--color-white); border-color: var(--color-black); }
.new-arrivals__arrow:disabled { opacity: 0.25; cursor: default; }
.new-arrivals__arrow svg { width: 18px; height: 18px; pointer-events: none; }

.na-card { flex: 0 0 auto; width: 260px; scroll-snap-align: start; position: relative; background: var(--color-gray-100); }
.na-card__media { position: relative; overflow: hidden; margin-bottom: 14px; }
.na-card__image-link { display: block; aspect-ratio: 3 / 4; }
.na-card__img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1); }
.na-card:hover .na-card__img { transform: scale(1.04); }
.na-card__placeholder { width: 100%; aspect-ratio: 3 / 4; background: var(--color-gray-100); display: flex; align-items: center; justify-content: center; }
.na-card__placeholder svg { width: 40%; opacity: 0.2; }
.na-card__badge {
  position: absolute;
  top: 12px;
  left: 12px;
  z-index: 3;
  font-family: var(--font-body);
  font-size: var(--text-xs);
  font-weight: 600;
  letter-spacing: 0.04em;
  background: var(--color-black);
  color: var(--color-white);
  padding: 4px 10px;
}
.na-card__overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 16px;
  z-index: 2;
  opacity: 0;
  transform: translateY(8px);
  transition: opacity 0.3s ease, transform 0.3s ease;
}
.na-card:hover .na-card__overlay { opacity: 1; transform: translateY(0); }
.na-card__cart-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  padding: 14px 20px;
  font-family: var(--font-body);
  font-size: var(--text-xs);
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  border: none;
  cursor: pointer;
  text-decoration: none;
  transition: background var(--transition-fast), color var(--transition-fast);
}
.na-card__cart-btn span { position: relative; z-index: 1; }
.na-card__cart-btn--add { background: var(--color-black); color: var(--color-white); }
.na-card__cart-btn--add:hover { background: var(--color-gray-800); }
.na-card__cart-btn--go { background: var(--color-white); color: var(--color-black); border: 1.5px solid var(--color-black); }
.na-card__cart-btn--go:hover { background: var(--color-black); color: var(--color-white); }
.na-card__zoom {
  position: absolute;
  top: 12px;
  right: 12px;
  z-index: 3;
  width: 36px;
  height: 36px;
  border-radius: 50%;
  background: var(--color-white);
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  opacity: 0;
  transform: scale(0.85);
  transition: opacity 0.3s ease, transform 0.3s ease,
              background var(--transition-fast), color var(--transition-fast);
  color: var(--color-black);
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
}
.na-card:hover .na-card__zoom { opacity: 1; transform: scale(1); }
.na-card__zoom:hover { background: var(--color-black); color: var(--color-white); }
.na-card__zoom svg { pointer-events: none; }
.na-card__info { display: flex; flex-direction: column; gap: 4px; padding: 10px 16px; }
.na-card__type {
  font-family: var(--font-body);
  font-size: var(--text-xs);
  font-weight: 500;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  color: var(--color-gray-400);
}
.na-card__title {
  font-family: var(--font-body);
  font-size: var(--text-sm);
  font-weight: 600;
  color: var(--color-black);
  text-decoration: none;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  transition: color var(--transition-fast);
}
.na-card__title:hover { color: var(--color-gray-600); }
.na-card__prices { display: flex; align-items: baseline; gap: 8px; margin-top: 2px; }
.na-card__price { font-family: var(--font-body); font-size: var(--text-base); font-weight: 700; color: var(--color-black); }
.na-card__compare-price { font-family: var(--font-body); font-size: var(--text-sm); color: var(--color-gray-400); text-decoration: line-through; }

.qv-modal {
  position: fixed;
  inset: 0;
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  visibility: hidden;
  transition: opacity 0.3s ease, visibility 0s 0.3s;
}
.qv-modal[aria-hidden="false"] { opacity: 1; visibility: visible; transition: opacity 0.3s ease, visibility 0s 0s; }
.qv-modal__backdrop { position: absolute; inset: 0; background: rgba(0,0,0,0.55); }
.qv-modal__dialog {
  position: relative;
  background: var(--color-white);
  max-width: 860px;
  width: 92%;
  max-height: 88vh;
  overflow-y: auto;
  z-index: 1;
  transform: translateY(16px);
  transition: transform 0.3s cubic-bezier(0.16,1,0.3,1);
}
.qv-modal[aria-hidden="false"] .qv-modal__dialog { transform: translateY(0); }
.qv-modal__close {
  position: absolute;
  top: 16px;
  right: 16px;
  z-index: 2;
  width: 40px;
  height: 40px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: none;
  border: 1.5px solid var(--color-gray-200);
  color: var(--color-black);
  cursor: pointer;
  transition: var(--transition-fast);
  padding: 0;
}
.qv-modal__close:hover { background: var(--color-black); color: var(--color-white); border-color: var(--color-black); }
.qv-modal__body { display: grid; grid-template-columns: 1fr 1fr; }
.qv-modal__image { background: var(--color-gray-100); aspect-ratio: 3/4; overflow: hidden; }
.qv-modal__img { width: 100%; height: 100%; object-fit: cover; display: block; }
.qv-modal__content { padding: 48px 40px; display: flex; flex-direction: column; justify-content: center; gap: 20px; }
.qv-modal__title { font-family: var(--font-display); font-size: var(--text-3xl); font-weight: 500; line-height: 1.2; color: var(--color-black); }
.qv-modal__prices { display: flex; align-items: baseline; gap: 12px; }
.qv-modal__price { font-family: var(--font-body); font-size: var(--text-xl); font-weight: 600; color: var(--color-black); }
.qv-modal__compare-price { font-family: var(--font-body); font-size: var(--text-base); color: var(--color-gray-400); text-decoration: line-through; }
.qv-modal__description { font-family: var(--font-body); font-size: var(--text-sm); line-height: 1.7; color: var(--color-gray-500); }
.qv-modal__variants { display: flex; flex-direction: column; gap: 10px; }
.qv-modal__variants-label { font-family: var(--font-body); font-size: var(--text-sm); color: var(--color-gray-500); }
.qv-modal__variants-label strong { color: var(--color-black); }
.qv-modal__variants-options { display: flex; flex-wrap: wrap; gap: 8px; }
.qv-modal__variant-btn {
  padding: 10px 20px;
  font-family: var(--font-body);
  font-size: var(--text-sm);
  font-weight: 500;
  background: var(--color-white);
  color: var(--color-black);
  border: 1.5px solid var(--color-gray-200);
  border-radius: 100px;
  cursor: pointer;
  transition: var(--transition-fast);
}
.qv-modal__variant-btn:hover { border-color: var(--color-black); }
.qv-modal__variant-btn.is-active { background: var(--color-black); color: var(--color-white); border-color: var(--color-black); }
.qv-modal__variant-btn.is-soldout { opacity: 0.35; text-decoration: line-through; cursor: not-allowed; }
.qv-modal__cart-row { display: flex; gap: 12px; align-items: stretch; }
.qv-modal__qty { display: flex; align-items: center; border: 1.5px solid var(--color-gray-200); border-radius: 100px; overflow: hidden; }
.qv-modal__qty-btn {
  width: 44px;
  height: 48px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: none;
  border: none;
  font-family: var(--font-body);
  font-size: var(--text-lg);
  color: var(--color-black);
  cursor: pointer;
  transition: background var(--transition-fast);
  user-select: none;
}
.qv-modal__qty-btn:hover { background: var(--color-gray-100); }
.qv-modal__qty-input {
  width: 40px;
  height: 48px;
  text-align: center;
  border: none;
  border-left: 1px solid var(--color-gray-200);
  border-right: 1px solid var(--color-gray-200);
  font-family: var(--font-body);
  font-size: var(--text-base);
  font-weight: 600;
  color: var(--color-black);
  background: none;
  -moz-appearance: textfield;
  outline: none;
}
.qv-modal__qty-input::-webkit-outer-spin-button,
.qv-modal__qty-input::-webkit-inner-spin-button { -webkit-appearance: none; margin: 0; }
.qv-modal__add-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 14px 24px;
  font-family: var(--font-body);
  font-size: var(--text-sm);
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  background: var(--color-gray-100);
  color: var(--color-black);
  border: none;
  border-radius: 100px;
  cursor: pointer;
  transition: var(--transition-fast);
}
.qv-modal__add-btn:hover:not(:disabled) { background: var(--color-gray-200); }
.qv-modal__add-btn:disabled { opacity: 0.4; cursor: not-allowed; }
.qv-modal__buy-now { width: 100%; border-radius: 100px; }
.qv-modal__buy-now:disabled { opacity: 0.4; cursor: not-allowed; }
.qv-modal__details-link {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-family: var(--font-body);
  font-size: var(--text-sm);
  font-weight: 600;
  color: var(--color-black);
  text-decoration: none;
  align-self: flex-start;
  border-bottom: 1px solid var(--color-black);
  padding-bottom: 2px;
  transition: color var(--transition-fast);
}
.qv-modal__details-link:hover { color: var(--color-gray-600); border-color: var(--color-gray-600); }
.qv-modal__details-link svg { transition: transform var(--transition-fast); }
.qv-modal__details-link:hover svg { transform: translateX(3px); }

@media (max-width: 992px) {
  .new-arrivals { padding: 60px 0; }
  .new-arrivals__promo { flex: 0 0 220px; }
  .na-card { width: 220px; }
  .qv-modal__body { grid-template-columns: 1fr; }
  .qv-modal__image { aspect-ratio: 4/3; max-height: 300px; }
  .qv-modal__content { padding: 32px 24px; }
  .qv-modal__dialog { max-width: 480px; }
  .qv-modal__cart-row { flex-direction: column; }
  .qv-modal__qty { align-self: flex-start; }
}
@media (max-width: 768px) {
  .new-arrivals { padding: 48px 0; }
  .new-arrivals__header { flex-direction: column; gap: 12px; margin-bottom: 24px; }
  .new-arrivals__main { flex-direction: column; }
  .new-arrivals__promo { flex: none; height: 260px; }
  .na-card { width: 180px; }
  .na-card__overlay { opacity: 1; transform: translateY(0); }
  .na-card__zoom { opacity: 1; transform: scale(1); }
  .new-arrivals__track { gap: 14px; }
  .new-arrivals__footer { margin-top: 24px; }
  .new-arrivals__progress { max-width: 120px; }
  .new-arrivals__arrow { width: 38px; height: 38px; }
  .qv-modal__content { padding: 24px 20px; }
  .qv-modal__title { font-size: var(--text-2xl); }
}
@media (max-width: 480px) {
  .na-card { width: 155px; }
  .na-card__badge { top: 8px; left: 8px; padding: 3px 8px; font-size: 10px; }
  .na-card__cart-btn { padding: 12px 14px; font-size: 0.7rem; letter-spacing: 0.08em; }
  .new-arrivals__arrow { width: 34px; height: 34px; }
}
{% endstylesheet %}

{% schema %}
{
  "name": "t:names.new_arrivals",
  "tag": "section",
  "class": "section-new-arrivals",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.heading",
      "default": "Daily Essentials"
    },
    {
      "type": "text",
      "id": "description",
      "label": "t:carousel_settings.description",
      "default": "Traditional divides between personal and professional space."
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "t:carousel_settings.collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "t:carousel_settings.products_to_show",
      "min": 4,
      "max": 20,
      "step": 1,
      "default": 12
    },
    {
      "type": "text",
      "id": "view_all_label",
      "label": "t:carousel_settings.shop_all_label",
      "default": "Shop All Products"
    },
    {
      "type": "header",
      "content": "t:carousel_settings.promo_card"
    },
    {
      "type": "image_picker",
      "id": "promo_image",
      "label": "t:carousel_settings.promo_image"
    },
    {
      "type": "text",
      "id": "promo_subtitle",
      "label": "t:carousel_settings.promo_subtitle",
      "default": "Big Saving"
    },
    {
      "type": "text",
      "id": "promo_heading",
      "label": "t:carousel_settings.promo_heading",
      "default": "On Holiday Sets"
    },
    {
      "type": "text",
      "id": "promo_button_label",
      "label": "t:carousel_settings.promo_button_label",
      "default": "Explore Now"
    },
    {
      "type": "url",
      "id": "promo_button_link",
      "label": "t:carousel_settings.promo_button_link"
    }
  ],
  "presets": [
    {
      "name": "t:names.new_arrivals"
    }
  ]
}
{% endschema %}