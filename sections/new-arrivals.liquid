{{ 'section-new-arrivals.css' | asset_url | stylesheet_tag }}

{%- assign collection = section.settings.collection -%}
{%- assign limit = section.settings.products_to_show | default: 12 -%}

<section class="new-arrivals section-{{ section.id }}">
  <div class="container">

    <div class="new-arrivals__header">
      <div class="new-arrivals__header-left">
        {%- if section.settings.heading != blank -%}
          <h2 class="new-arrivals__heading heading-section">{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.description != blank -%}
          <p class="new-arrivals__description">{{ section.settings.description }}</p>
        {%- endif -%}
      </div>
      {%- if section.settings.view_all_label != blank and collection != blank -%}
        <a href="{{ collection.url }}" class="new-arrivals__shop-all link-arrow">
          {{ section.settings.view_all_label }}
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
        </a>
      {%- endif -%}
    </div>

    <div class="new-arrivals__main">

      {%- if section.settings.promo_image != blank or section.settings.promo_heading != blank -%}
        <div class="new-arrivals__promo">
          {%- if section.settings.promo_image != blank -%}
            {{ section.settings.promo_image | image_url: width: 600 | image_tag:
              loading: 'lazy',
              widths: '300, 400, 600',
              class: 'new-arrivals__promo-bg'
            }}
          {%- endif -%}
          <div class="new-arrivals__promo-overlay"></div>
          <div class="new-arrivals__promo-content">
            {%- if section.settings.promo_subtitle != blank -%}
              <span class="new-arrivals__promo-subtitle">{{ section.settings.promo_subtitle }}</span>
            {%- endif -%}
            {%- if section.settings.promo_heading != blank -%}
              <h3 class="new-arrivals__promo-heading">{{ section.settings.promo_heading }}</h3>
            {%- endif -%}
            {%- if section.settings.promo_button_label != blank -%}
              <a href="{{ section.settings.promo_button_link | default: collection.url }}" class="new-arrivals__promo-link link-arrow">
                {{ section.settings.promo_button_label }}
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
              </a>
            {%- endif -%}
          </div>
        </div>
      {%- endif -%}

      <div class="new-arrivals__track-wrapper">
        <div class="new-arrivals__track">

          {%- if collection != blank -%}
            {%- for product in collection.products limit: limit -%}
              {%- assign has_discount = false -%}
              {%- if product.compare_at_price > product.price -%}
                {%- assign has_discount = true -%}
              {%- endif -%}

              {%- assign in_cart = false -%}
              {%- for item in cart.items -%}
                {%- if item.product_id == product.id -%}
                  {%- assign in_cart = true -%}
                  {%- break -%}
                {%- endif -%}
              {%- endfor -%}

              <div class="na-card" data-product-id="{{ product.id }}" data-variant-id="{{ product.selected_or_first_available_variant.id }}" data-in-cart="{{ in_cart }}">
                <div class="na-card__media">
                  <a href="{{ product.url }}" class="na-card__image-link">
                    {%- if product.featured_image -%}
                      {%- if forloop.first -%}
                        {{ product.featured_image | image_url: width: 600 | image_tag:
                          loading: 'eager',
                          widths: '300, 400, 600',
                          sizes: '(max-width: 768px) 50vw, 280px',
                          class: 'na-card__img'
                        }}
                      {%- else -%}
                        {{ product.featured_image | image_url: width: 600 | image_tag:
                          loading: 'lazy',
                          widths: '300, 400, 600',
                          sizes: '(max-width: 768px) 50vw, 280px',
                          class: 'na-card__img'
                        }}
                      {%- endif -%}
                    {%- else -%}
                      <div class="na-card__placeholder">
                        {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
                      </div>
                    {%- endif -%}
                  </a>

                  {%- if has_discount -%}
                    {%- assign discount_pct = product.compare_at_price | minus: product.price | times: 100.0 | divided_by: product.compare_at_price | round -%}
                    <span class="na-card__badge">-{{ discount_pct }}%</span>
                  {%- endif -%}

                  <div class="na-card__overlay">
                    {%- if in_cart -%}
                      <a href="{{ routes.cart_url }}" class="na-card__cart-btn na-card__cart-btn--go">
                        <span>Go to Cart</span>
                      </a>
                    {%- else -%}
                      <button type="button" class="na-card__cart-btn na-card__cart-btn--add" data-variant-id="{{ product.selected_or_first_available_variant.id }}">
                        <span>Add to Cart</span>
                      </button>
                    {%- endif -%}
                  </div>

                  <button type="button" class="na-card__zoom" aria-label="Quick view {{ product.title }}" data-product-handle="{{ product.handle }}">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                      <circle cx="11" cy="11" r="8"></circle>
                      <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
                      <line x1="11" y1="8" x2="11" y2="14"></line>
                      <line x1="8" y1="11" x2="14" y2="11"></line>
                    </svg>
                  </button>
                </div>

                <div class="na-card__info">
                  {%- if product.type != blank -%}
                    <span class="na-card__type">{{ product.type }}</span>
                  {%- endif -%}
                  <a href="{{ product.url }}" class="na-card__title">{{ product.title }}</a>
                  <div class="na-card__prices">
                    <span class="na-card__price">{{ product.price | money }}</span>
                    {%- if has_discount -%}
                      <span class="na-card__compare-price">{{ product.compare_at_price | money }}</span>
                    {%- endif -%}
                  </div>
                </div>
              </div>

            {%- endfor -%}
          {%- else -%}
            {%- for i in (1..6) -%}
              <div class="na-card na-card--placeholder">
                <div class="na-card__media">
                  <div class="na-card__placeholder">
                    {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
                  </div>
                </div>
                <div class="na-card__info">
                  <span class="na-card__type">Category</span>
                  <span class="na-card__title">Product Title</span>
                  <div class="na-card__prices">
                    <span class="na-card__price">{{ 2999 | money }}</span>
                  </div>
                </div>
              </div>
            {%- endfor -%}
          {%- endif -%}

        </div>
      </div>
    </div>

    <div class="new-arrivals__footer">
      <div class="new-arrivals__progress">
        <div class="new-arrivals__progress-bar"></div>
      </div>
      <div class="new-arrivals__arrows">
        <button class="new-arrivals__arrow new-arrivals__arrow--prev" aria-label="Previous">
          {{ 'icon-chevron-left.svg' | inline_asset_content }}
        </button>
        <button class="new-arrivals__arrow new-arrivals__arrow--next" aria-label="Next">
          {{ 'icon-chevron-right.svg' | inline_asset_content }}
        </button>
      </div>
    </div>

  </div>
</section>

<div class="qv-modal" id="qv-modal-{{ section.id }}" aria-hidden="true">
  <div class="qv-modal__backdrop"></div>
  <div class="qv-modal__dialog" role="dialog" aria-label="Quick view">
    <button class="qv-modal__close" aria-label="Close">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <line x1="18" y1="6" x2="6" y2="18"></line>
        <line x1="6" y1="6" x2="18" y2="18"></line>
      </svg>
    </button>
    <div class="qv-modal__body">
      <div class="qv-modal__image">
        <img src="" alt="" class="qv-modal__img">
      </div>
      <div class="qv-modal__content">
        <h3 class="qv-modal__title"></h3>
        <div class="qv-modal__prices">
          <span class="qv-modal__price"></span>
          <span class="qv-modal__compare-price"></span>
        </div>
        <p class="qv-modal__description"></p>
        <div class="qv-modal__variants" style="display:none;">
          <span class="qv-modal__variants-label">Size: <strong class="qv-modal__variants-selected"></strong></span>
          <div class="qv-modal__variants-options"></div>
        </div>
        <div class="qv-modal__cart-row">
          <div class="qv-modal__qty">
            <button type="button" class="qv-modal__qty-btn" data-action="minus" aria-label="Decrease">−</button>
            <input type="number" class="qv-modal__qty-input" value="1" min="1" max="99" aria-label="Quantity">
            <button type="button" class="qv-modal__qty-btn" data-action="plus" aria-label="Increase">+</button>
          </div>
          <button type="button" class="qv-modal__add-btn">
            <span>Add to Cart</span>
          </button>
        </div>
        <button type="button" class="qv-modal__buy-now btn btn-primary">
          <span>Buy It Now</span>
        </button>
        <a href="#" class="qv-modal__details-link">
          View Full Details
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
        </a>
      </div>
    </div>
  </div>
</div>

<script>
(function () {
  var section = document.querySelector('.new-arrivals.section-{{ section.id }}');
  var modal = document.getElementById('qv-modal-{{ section.id }}');
  if (!section) return;

  var track = section.querySelector('.new-arrivals__track');
  var prevBtn = section.querySelector('.new-arrivals__arrow--prev');
  var nextBtn = section.querySelector('.new-arrivals__arrow--next');
  var progressBar = section.querySelector('.new-arrivals__progress-bar');

  function getScrollAmount() {
    var card = track.querySelector('.na-card');
    if (!card) return 300;
    var gap = parseInt(getComputedStyle(track).gap) || 20;
    return (card.offsetWidth + gap) * 2;
  }

  function updateControls() {
    var sl = track.scrollLeft;
    var max = track.scrollWidth - track.clientWidth;

    prevBtn.disabled = sl <= 4;
    nextBtn.disabled = sl >= max - 4;

    if (max > 0 && progressBar) {
      var pct = (sl / max) * 100;
      progressBar.style.width = Math.max(10, Math.min(100, pct)) + '%';
    }
  }

  prevBtn.addEventListener('click', function () {
    track.scrollBy({ left: -getScrollAmount(), behavior: 'smooth' });
  });
  nextBtn.addEventListener('click', function () {
    track.scrollBy({ left: getScrollAmount(), behavior: 'smooth' });
  });
  track.addEventListener('scroll', updateControls, { passive: true });
  updateControls();
  window.addEventListener('resize', updateControls);

  section.querySelectorAll('.na-card__cart-btn--add').forEach(function (btn) {
    btn.addEventListener('click', function (e) {
      e.preventDefault();
      var variantId = this.getAttribute('data-variant-id');
      var card = this.closest('.na-card');
      var btnEl = this;
      btnEl.querySelector('span').textContent = 'Adding...';
      btnEl.disabled = true;

      fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ items: [{ id: parseInt(variantId), quantity: 1 }] })
      })
      .then(function (r) { return r.json(); })
      .then(function () {
        card.setAttribute('data-in-cart', 'true');
        var overlay = card.querySelector('.na-card__overlay');
        overlay.innerHTML = '<a href="/cart" class="na-card__cart-btn na-card__cart-btn--go"><span>Go to Cart</span></a>';
      })
      .catch(function () {
        btnEl.querySelector('span').textContent = 'Add to Cart';
        btnEl.disabled = false;
      });
    });
  });

  /* ── Quick View Modal ── */
  var modalImg = modal.querySelector('.qv-modal__img');
  var modalTitle = modal.querySelector('.qv-modal__title');
  var modalPrice = modal.querySelector('.qv-modal__price');
  var modalCompare = modal.querySelector('.qv-modal__compare-price');
  var modalDesc = modal.querySelector('.qv-modal__description');
  var modalQtyInput = modal.querySelector('.qv-modal__qty-input');
  var modalAddBtn = modal.querySelector('.qv-modal__add-btn');
  var modalBuyBtn = modal.querySelector('.qv-modal__buy-now');
  var modalDetailsLink = modal.querySelector('.qv-modal__details-link');
  var modalVariantsWrap = modal.querySelector('.qv-modal__variants');
  var modalVariantsOptions = modal.querySelector('.qv-modal__variants-options');
  var modalVariantsSelected = modal.querySelector('.qv-modal__variants-selected');
  var currentVariantId = null;
  var currentProductData = null;

  function formatMoney(cents) {
    var curr = (Shopify.currency && Shopify.currency.active) ? Shopify.currency.active : 'INR';
    return new Intl.NumberFormat(Shopify.locale || 'en', {
      style: 'currency', currency: curr
    }).format(cents / 100);
  }

  function updateModalPrices(variant) {
    modalPrice.textContent = formatMoney(variant.price);
    if (variant.compare_at_price && variant.compare_at_price > variant.price) {
      modalCompare.textContent = formatMoney(variant.compare_at_price);
      modalCompare.style.display = '';
    } else {
      modalCompare.textContent = '';
      modalCompare.style.display = 'none';
    }
  }

  function selectVariant(variantId) {
    if (!currentProductData) return;
    var variant = currentProductData.variants.find(function (v) { return v.id === variantId; });
    if (!variant) return;
    currentVariantId = variant.id;
    updateModalPrices(variant);
    if (variant.title && variant.title !== 'Default Title') {
      modalVariantsSelected.textContent = variant.title;
    }
    modalVariantsOptions.querySelectorAll('.qv-modal__variant-btn').forEach(function (btn) {
      btn.classList.toggle('is-active', parseInt(btn.getAttribute('data-variant-id')) === variantId);
    });
    if (variant.featured_image) {
      modalImg.src = variant.featured_image.src.replace(/(\.\w+)$/, '_600x$1');
    }
    if (!variant.available) {
      modalAddBtn.disabled = true;
      modalAddBtn.querySelector('span').textContent = 'Sold Out';
      modalBuyBtn.disabled = true;
      modalBuyBtn.querySelector('span').textContent = 'Sold Out';
    } else {
      modalAddBtn.disabled = false;
      modalAddBtn.querySelector('span').textContent = 'Add to Cart';
      modalBuyBtn.disabled = false;
      modalBuyBtn.querySelector('span').textContent = 'Buy It Now';
    }
  }

  section.querySelectorAll('.na-card__zoom').forEach(function (btn) {
    btn.addEventListener('click', function (e) {
      e.preventDefault();
      var handle = this.getAttribute('data-product-handle');
      modalQtyInput.value = 1;
      modalAddBtn.querySelector('span').textContent = 'Add to Cart';
      modalAddBtn.disabled = false;
      modalBuyBtn.querySelector('span').textContent = 'Buy It Now';
      modalBuyBtn.disabled = false;
      fetch('/products/' + handle + '.js')
        .then(function (r) { return r.json(); })
        .then(function (product) {
          currentProductData = product;
          var variant = product.variants[0];
          currentVariantId = variant.id;
          modalImg.src = product.featured_image ? product.featured_image.replace(/(\.\w+)$/, '_600x$1') : '';
          modalImg.alt = product.title;
          modalTitle.textContent = product.title;
          updateModalPrices(variant);
          modalDesc.textContent = product.description
            ? product.description.replace(/<[^>]*>/g, '').substring(0, 200) + (product.description.length > 200 ? '...' : '')
            : '';
          modalDetailsLink.href = '/products/' + handle;
          if (product.variants.length > 1 && !(product.variants.length === 1 && product.variants[0].title === 'Default Title')) {
            modalVariantsWrap.style.display = '';
            modalVariantsOptions.innerHTML = '';
            var optionName = product.options[0] || 'Size';
            modalVariantsWrap.querySelector('.qv-modal__variants-label').innerHTML =
              optionName + ': <strong class="qv-modal__variants-selected">' + variant.title + '</strong>';
            modalVariantsSelected = modalVariantsWrap.querySelector('.qv-modal__variants-selected');
            product.variants.forEach(function (v) {
              var vBtn = document.createElement('button');
              vBtn.type = 'button';
              vBtn.className = 'qv-modal__variant-btn' + (v.id === variant.id ? ' is-active' : '');
              if (!v.available) vBtn.className += ' is-soldout';
              vBtn.setAttribute('data-variant-id', v.id);
              vBtn.textContent = v.title;
              vBtn.addEventListener('click', function () {
                selectVariant(parseInt(this.getAttribute('data-variant-id')));
              });
              modalVariantsOptions.appendChild(vBtn);
            });
          } else {
            modalVariantsWrap.style.display = 'none';
          }
          modal.setAttribute('aria-hidden', 'false');
          document.body.style.overflow = 'hidden';
        });
    });
  });

  function closeModal() {
    modal.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
    currentProductData = null;
  }
  modal.querySelector('.qv-modal__close').addEventListener('click', closeModal);
  modal.querySelector('.qv-modal__backdrop').addEventListener('click', closeModal);
  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape' && modal.getAttribute('aria-hidden') === 'false') closeModal();
  });

  modal.querySelectorAll('.qv-modal__qty-btn').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var val = parseInt(modalQtyInput.value) || 1;
      if (this.getAttribute('data-action') === 'minus') {
        modalQtyInput.value = Math.max(1, val - 1);
      } else {
        modalQtyInput.value = Math.min(99, val + 1);
      }
    });
  });

  modalAddBtn.addEventListener('click', function () {
    if (!currentVariantId) return;
    var qty = parseInt(modalQtyInput.value) || 1;
    var btnSpan = this.querySelector('span');
    btnSpan.textContent = 'Adding...';
    this.disabled = true;
    fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ items: [{ id: currentVariantId, quantity: qty }] })
    })
    .then(function (r) { return r.json(); })
    .then(function () {
      btnSpan.textContent = 'Added ✓';
      setTimeout(function () { closeModal(); }, 800);
      var card = section.querySelector('[data-variant-id="' + currentVariantId + '"]');
      if (card) {
        card.setAttribute('data-in-cart', 'true');
        var overlay = card.querySelector('.na-card__overlay');
        if (overlay) overlay.innerHTML = '<a href="/cart" class="na-card__cart-btn na-card__cart-btn--go"><span>Go to Cart</span></a>';
      }
    })
    .catch(function () { btnSpan.textContent = 'Add to Cart'; modalAddBtn.disabled = false; });
  });

  modalBuyBtn.addEventListener('click', function () {
    if (!currentVariantId) return;
    var qty = parseInt(modalQtyInput.value) || 1;
    var btnSpan = this.querySelector('span');
    btnSpan.textContent = 'Redirecting...';
    this.disabled = true;
    fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ items: [{ id: currentVariantId, quantity: qty }] })
    })
    .then(function () { window.location.href = '/checkout'; })
    .catch(function () { btnSpan.textContent = 'Buy It Now'; modalBuyBtn.disabled = false; });
  });
})();
</script>

{% schema %}
{
  "name": "New Arrivals",
  "tag": "section",
  "class": "section-new-arrivals",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Daily Essentials"
    },
    {
      "type": "text",
      "id": "description",
      "label": "Description",
      "default": "Traditional divides between personal and professional space."
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Products to show",
      "min": 4,
      "max": 20,
      "step": 1,
      "default": 12
    },
    {
      "type": "text",
      "id": "view_all_label",
      "label": "Shop all link text",
      "default": "Shop All Products"
    },
    {
      "type": "header",
      "content": "Promo card (left side)"
    },
    {
      "type": "image_picker",
      "id": "promo_image",
      "label": "Promo image"
    },
    {
      "type": "text",
      "id": "promo_subtitle",
      "label": "Promo subtitle",
      "default": "Big Saving"
    },
    {
      "type": "text",
      "id": "promo_heading",
      "label": "Promo heading",
      "default": "On Holiday Sets"
    },
    {
      "type": "text",
      "id": "promo_button_label",
      "label": "Promo button label",
      "default": "Explore Now"
    },
    {
      "type": "url",
      "id": "promo_button_link",
      "label": "Promo button link"
    }
  ],
  "presets": [
    {
      "name": "New Arrivals"
    }
  ]
}
{% endschema %}