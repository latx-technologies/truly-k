{% comment %}
  This section is used in the page template to render store pages like About us
  or Contact us.

  https://shopify.dev/docs/storefronts/themes/architecture/templates/page
{% endcomment %}

<div class="page">
  <div class="page__content rte">
    {{ page.content }}
  </div>
</div>

{% stylesheet %}
  .page {
    max-width: 70rem;
    margin: 0 auto;
    padding: 32px var(--container-padding, 24px) 64px;
  }
  .page__content > *:first-child { margin-top: 0; }
  .page__content > *:last-child  { margin-bottom: 0; }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.page",
  "settings": []
}
{% endschema %}
