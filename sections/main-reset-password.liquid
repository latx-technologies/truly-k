{% comment %}
  Used by templates/customers/reset_password.json. Renders the form that lets
  the customer set a new password after clicking the recovery email link.
{% endcomment %}

<section
  class="auth-page"
  style="
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;
  "
>
  <div class="container">
    <div class="auth-page__content auth-page__content--narrow">
      <div class="auth-card">
        <header class="auth-card__header">
          <span class="auth-card__eyebrow text-label">{{ 'customer.reset_password.eyebrow' | t }}</span>
          <h1 class="auth-card__title heading-section">{{ 'customer.reset_password.title' | t }}</h1>
          <p class="auth-card__subtitle text-muted">{{ 'customer.reset_password.subtitle' | t }}</p>
        </header>

        {%- form 'reset_customer_password', novalidate: 'novalidate' -%}
          {%- if form.errors -%}
            <div class="form-error-list" role="alert">
              {%- for field in form.errors -%}
                <p class="form-error">{{ form.errors.translated_fields[field] | capitalize }} {{ form.errors.messages[field] }}</p>
              {%- endfor -%}
            </div>
          {%- endif -%}

          <div class="form-field">
            <label class="form-field__label" for="reset-password">{{ 'customer.reset_password.password' | t }}</label>
            <input
              class="form-field__input"
              type="password"
              id="reset-password"
              name="customer[password]"
              autocomplete="new-password"
              required
            >
          </div>

          <div class="form-field">
            <label class="form-field__label" for="reset-password-confirmation">{{ 'customer.reset_password.password_confirm' | t }}</label>
            <input
              class="form-field__input"
              type="password"
              id="reset-password-confirmation"
              name="customer[password_confirmation]"
              autocomplete="new-password"
              required
            >
          </div>

          <button type="submit" class="btn btn-primary auth-card__submit">
            <span>{{ 'customer.reset_password.submit' | t }}</span>
          </button>
        {%- endform -%}
      </div>
    </div>
  </div>
</section>

{% stylesheet %}
  .auth-page__content--narrow {
    max-width: 480px;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:names.main_reset_password",
  "settings": [
    {
      "type": "range",
      "id": "padding_top",
      "label": "t:carousel_settings.padding_top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 96
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "t:carousel_settings.padding_bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 96
    }
  ]
}
{% endschema %}
