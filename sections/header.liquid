<header class="site-header">
  <div class="header-top">
    <div class="header-top__inner">
      <div class="header-top__logo">
        <a href="{{ routes.root_url }}">
          {% if section.settings.logo != blank %}
            {{ section.settings.logo | image_url: width: 300 | image_tag: class: 'header-logo-img', loading: 'eager' }}
          {% else %}
            <span class="header-logo-text">
              {{ shop.name }}
            </span>
          {% endif %}
        </a>
      </div>

      <div class="header-top__actions">
        {% if section.settings.show_store_locator %}
          <a href="{{ section.settings.store_locator_url | default: '/pages/store-locator' }}" class="header-action">
            <span class="header-action__icon">
              {{ 'icon-map-pin.svg' | inline_asset_content }}
            </span>
            <span class="header-action__label">{{ 'header.find_a_store' | t }}</span>
          </a>
        {% endif %}

        {% if shop.customer_accounts_enabled %}
          <a href="{{ routes.account_url }}" class="header-action">
            <span class="header-action__icon">
              {{ 'icon-account.svg' | inline_asset_content }}
            </span>
            <span class="header-action__label">
              {% if customer %}
                {{ 'header.account' | t }}
              {% else %}
                {{ 'header.sign_in_register' | t }}
              {% endif %}
            </span>
          </a>
        {% endif %}

        <a href="{{ routes.cart_url }}" class="header-action header-action--cart">
          <span class="header-action__icon">
            {{ 'icon-cart.svg' | inline_asset_content }}
          </span>
          {% if cart.item_count > 0 %}
            <span class="header-cart-count">{{ cart.item_count }}</span>
          {% endif %}
        </a>
      </div>
    </div>
  </div>

  <nav class="header-nav full-width" aria-label="{{ 'header.main_navigation' | t }}">
    <div class="header-nav__inner">
      <button class="header-nav__mobile-toggle" aria-label="{{ 'header.open_menu' | t }}" aria-expanded="false" aria-controls="header-nav-list">
        <span></span>
        <span></span>
        <span></span>
      </button>

      <div class="header-nav__drawer" id="header-nav-list">
        <div class="header-nav__drawer-head">
          <a href="{{ routes.root_url }}" class="header-nav__drawer-logo">
            {% if section.settings.logo != blank %}
              {{ section.settings.logo | image_url: width: 240 | image_tag: loading: 'lazy', class: 'header-nav__drawer-logo-img' }}
            {% else %}
              <span>{{ shop.name }}</span>
            {% endif %}
          </a>
          <button class="header-nav__drawer-close" type="button" aria-label="{{ 'header.close_menu' | t }}">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
          </button>
        </div>

        <ul class="header-nav__list">
        {% for link in section.settings.menu.links %}
          {%- liquid
            assign has_children = false
            assign is_mega = false
            assign mega_variant = 'grid'
            if link.links.size > 0
              assign has_children = true
              for child in link.links
                if child.links.size > 0
                  assign is_mega = true
                  break
                endif
              endfor
              if is_mega
                for block in section.blocks
                  if block.type == 'mega_menu'
                    assign block_title = block.settings.menu_item_title | strip
                    if block_title != blank and link.title == block_title
                      assign mega_variant = block.settings.variant
                      assign mega_collection = block.settings.featured_collection
                      break
                    endif
                  endif
                endfor
              endif
            endif
          -%}

          <li class="header-nav__item{% if has_children %} has-dropdown{% endif %}{% if is_mega %} has-mega has-mega--{{ mega_variant }}{% endif %}">
            {% if has_children %}
              <button class="header-nav__link" aria-expanded="false">
                {{ link.title }}
                <span class="header-nav__chevron">
                  {{ 'icon-chevron-down.svg' | inline_asset_content }}
                </span>
              </button>

              {% if is_mega %}
                {% if mega_variant == 'columns' %}
                  {%- comment -%} Variant 2: Four columns with product cards {%- endcomment -%}
                  <div class="header-mega header-mega--columns">
                    <div class="header-mega__inner">
                      {% for child_link in link.links limit: 3 %}
                        <div class="header-mega__column{% if child_link.links.size > 0 %} has-sub{% endif %}">
                          {% if child_link.links.size > 0 %}
                            <button type="button" class="header-mega__heading header-mega__heading--toggle" aria-expanded="false">
                              {{ child_link.title }}
                              <span class="header-mega__heading-chevron" aria-hidden="true">
                                {{ 'icon-chevron-down.svg' | inline_asset_content }}
                              </span>
                            </button>
                            <ul class="header-mega__list">
                              {% for grandchild in child_link.links %}
                                <li>
                                  <a href="{{ grandchild.url }}" class="header-mega__link">
                                    {{ grandchild.title }}
                                  </a>
                                </li>
                              {% endfor %}
                            </ul>
                          {% else %}
                            <a href="{{ child_link.url }}" class="header-mega__heading">
                              {{ child_link.title }}
                            </a>
                          {% endif %}
                        </div>
                      {% endfor %}
                      {% if mega_collection != blank %}
                        <div class="header-mega__column header-mega__products">
                          <span class="header-mega__heading header-mega__heading--static">{{ 'header.trending_products' | t }}</span>
                          <div class="header-mega__product-grid">
                            {% for product in mega_collection.products limit: 3 %}
                              <a href="{{ product.url }}" class="header-mega__product-card">
                                <div class="header-mega__product-image">
                                  {% if product.featured_image %}
                                    {{ product.featured_image | image_url: width: 200 | image_tag: loading: 'lazy' }}
                                  {% else %}
                                    {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
                                  {% endif %}
                                  {% if product.tags contains 'new' %}
                                    <span class="header-mega__product-badge">{{ 'header.new_badge' | t }}</span>
                                  {% endif %}
                                </div>
                                <span class="header-mega__product-title">{{ product.title }}</span>
                                <span class="header-mega__product-price">{{ product.price | money }}</span>
                              </a>
                            {% endfor %}
                          </div>
                        </div>
                      {% endif %}
                    </div>
                  </div>
                {% else %}
                  {%- comment -%} Variant 1: Left nav + image grid {%- endcomment -%}
                  <div class="header-mega header-mega--grid">
                    <div class="header-mega__inner header-mega__inner--grid">
                      <nav class="header-mega__nav">
                        {% for child_link in link.links %}
                          {% if child_link.links.size > 0 %}
                            <button type="button" class="header-mega__nav-item header-mega__nav-item--toggle{% if forloop.first %} is-active{% endif %}" data-index="{{ forloop.index0 }}" aria-expanded="false">
                              {{ child_link.title }}
                              <span class="header-mega__nav-chevron" aria-hidden="true">{{ 'icon-chevron-right.svg' | inline_asset_content }}</span>
                            </button>
                          {% else %}
                            <a href="{{ child_link.url }}" class="header-mega__nav-item{% if forloop.first %} is-active{% endif %}" data-index="{{ forloop.index0 }}">
                              {{ child_link.title }}
                              <span class="header-mega__nav-chevron" aria-hidden="true">{{ 'icon-chevron-right.svg' | inline_asset_content }}</span>
                            </a>
                          {% endif %}
                        {% endfor %}
                      </nav>
                      <div class="header-mega__grid-wrap">
                        {% for child_link in link.links %}
                          <div class="header-mega__grid-panel{% if forloop.first %} is-active{% endif %}" data-index="{{ forloop.index0 }}">
                            <div class="header-mega__grid">
                              {% if child_link.links.size > 0 %}
                                {% for grandchild in child_link.links limit: 8 %}
                                  {%- liquid
                                    assign gc_object = grandchild.object
                                    assign gc_image = null
                                    if grandchild.type == 'product_link' and gc_object.featured_image
                                      assign gc_image = gc_object.featured_image
                                    elsif grandchild.type == 'collection_link' and gc_object.image
                                      assign gc_image = gc_object.image
                                    elsif gc_object.featured_image
                                      assign gc_image = gc_object.featured_image
                                    elsif gc_object.image
                                      assign gc_image = gc_object.image
                                    endif
                                  -%}
                                  <a href="{{ grandchild.url }}" class="header-mega__grid-item">
                                    <div class="header-mega__grid-image">
                                      {% if gc_image %}
                                        {{ gc_image | image_url: width: 300 | image_tag: loading: 'lazy' }}
                                      {% else %}
                                        {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}
                                      {% endif %}
                                    </div>
                                    <span class="header-mega__grid-label">{{ grandchild.title }}</span>
                                  </a>
                                {% endfor %}
                              {% endif %}
                            </div>
                          </div>
                        {% endfor %}
                      </div>
                    </div>
                  </div>
                {% endif %}
              {% else %}
                {%- comment -%} Regular narrow dropdown {%- endcomment -%}
                <ul class="header-nav__dropdown">
                  {% for child_link in link.links %}
                    <li>
                      <a href="{{ child_link.url }}" class="header-nav__dropdown-link">
                        {{ child_link.title }}
                      </a>
                    </li>
                  {% endfor %}
                </ul>
              {% endif %}

            {% else %}
              <a href="{{ link.url }}" class="header-nav__link">
                {{ link.title }}
              </a>
            {% endif %}
          </li>
        {% endfor %}

        {% if section.settings.show_on_sale_link %}
          <li class="header-nav__item header-nav__item--sale">
            <a href="{{ section.settings.on_sale_url | default: '/collections/sale' }}" class="header-nav__sale-btn">
              {{ section.settings.on_sale_text | default: 'On Sale' }}
            </a>
          </li>
        {% endif %}
        </ul>
      </div>
      <div class="header-nav__backdrop" aria-hidden="true"></div>
    </div>
  </nav>
</header>

{% javascript %}
(function () {
  var MOBILE_BREAKPOINT = 900;
  var toggle = document.querySelector('.header-nav__mobile-toggle');
  var drawer = document.getElementById('header-nav-list');
  var backdrop = document.querySelector('.header-nav__backdrop');
  var closeBtn = document.querySelector('.header-nav__drawer-close');
  var siteHeader = document.querySelector('.site-header');
  var backIconSvg = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M15 18l-6-6 6-6"/></svg>';

  function isMobile() { return window.innerWidth < MOBILE_BREAKPOINT; }

  function lockBodyScroll(lock) {
    document.body.style.overflow = lock ? 'hidden' : '';
  }

  function injectBackRow(panel, title, onBack) {
    if (!panel || panel.querySelector(':scope > .header-nav__back-row')) return;
    var row = document.createElement('div');
    row.className = 'header-nav__back-row';
    var btn = document.createElement('button');
    btn.type = 'button';
    btn.className = 'header-nav__back';
    btn.setAttribute('aria-label', 'Back');
    btn.innerHTML = backIconSvg;
    btn.addEventListener('click', function (e) {
      e.preventDefault();
      e.stopPropagation();
      onBack();
    });
    var label = document.createElement('span');
    label.className = 'header-nav__back-title';
    label.textContent = title || '';
    row.appendChild(btn);
    row.appendChild(label);
    panel.insertBefore(row, panel.firstChild);
  }

  function setupBackRows() {
    if (!drawer) return;

    // Level 2: top-level items with children
    drawer.querySelectorAll('.header-nav__item.has-dropdown').forEach(function (item) {
      var panel = item.querySelector(':scope > .header-mega, :scope > .header-nav__dropdown');
      if (!panel) return;
      var link = item.querySelector(':scope > .header-nav__link');
      var title = link ? link.textContent.trim() : '';
      injectBackRow(panel, title, function () {
        item.classList.remove('dropdown-open');
        if (link) link.setAttribute('aria-expanded', 'false');
      });
    });

    // Level 3: grid-variant subcategory panels
    drawer.querySelectorAll('.header-nav__item.has-mega--grid').forEach(function (item) {
      var navItems = item.querySelectorAll('.header-mega__nav-item');
      var panels = item.querySelectorAll('.header-mega__grid-panel');
      navItems.forEach(function (navItem, i) {
        if (!panels[i]) return;
        var title = (navItem.firstChild && navItem.firstChild.textContent) ? navItem.firstChild.textContent.trim() : navItem.textContent.trim();
        injectBackRow(panels[i], title, function () {
          navItem.classList.remove('is-open');
          if (navItem.hasAttribute('aria-expanded')) navItem.setAttribute('aria-expanded', 'false');
          panels[i].classList.remove('is-open');
        });
      });
    });

    // Level 3: columns-variant heading lists
    drawer.querySelectorAll('.header-mega__column.has-sub').forEach(function (col) {
      var list = col.querySelector('.header-mega__list');
      var headBtn = col.querySelector('.header-mega__heading--toggle');
      if (!list || !headBtn) return;
      var title = headBtn.firstChild ? headBtn.firstChild.textContent.trim() : headBtn.textContent.trim();
      injectBackRow(list, title, function () {
        col.classList.remove('is-open');
        headBtn.setAttribute('aria-expanded', 'false');
      });
    });
  }

  function closeAllSubmenus() {
    if (!drawer) return;
    drawer.querySelectorAll('.header-nav__item.dropdown-open').forEach(function (item) {
      item.classList.remove('dropdown-open');
      var link = item.querySelector('.header-nav__link');
      if (link) link.setAttribute('aria-expanded', 'false');
    });
    drawer.querySelectorAll('.header-mega__column.is-open').forEach(function (col) {
      col.classList.remove('is-open');
      var btn = col.querySelector('.header-mega__heading--toggle');
      if (btn) btn.setAttribute('aria-expanded', 'false');
    });
    drawer.querySelectorAll('.header-mega__nav-item.is-open').forEach(function (n) {
      n.classList.remove('is-open');
      n.setAttribute('aria-expanded', 'false');
    });
    drawer.querySelectorAll('.header-mega__grid-panel.is-open').forEach(function (p) {
      p.classList.remove('is-open');
    });
  }

  function closeMenu() {
    if (!toggle || !drawer) return;
    toggle.setAttribute('aria-expanded', 'false');
    toggle.classList.remove('is-active');
    drawer.classList.remove('is-open');
    if (backdrop) backdrop.classList.remove('is-open');
    closeAllSubmenus();
    lockBodyScroll(false);
  }

  function openMenu() {
    if (!toggle || !drawer) return;
    toggle.setAttribute('aria-expanded', 'true');
    toggle.classList.add('is-active');
    drawer.classList.add('is-open');
    if (backdrop) backdrop.classList.add('is-open');
    lockBodyScroll(true);
  }

  if (toggle && drawer) {
    toggle.addEventListener('click', function (e) {
      e.stopPropagation();
      if (drawer.classList.contains('is-open')) closeMenu();
      else openMenu();
    });
  }
  if (closeBtn) closeBtn.addEventListener('click', closeMenu);
  if (backdrop) backdrop.addEventListener('click', closeMenu);

  // Top-level toggle (button-only on items with children)
  document.querySelectorAll('.header-nav__item.has-dropdown > .header-nav__link').forEach(function (btn) {
    btn.addEventListener('click', function (e) {
      if (isMobile()) {
        e.preventDefault();
        e.stopPropagation();
        var parent = this.parentElement;
        var willOpen = !parent.classList.contains('dropdown-open');
        if (drawer) {
          drawer.querySelectorAll('.header-nav__item.dropdown-open').forEach(function (item) {
            if (item !== parent) {
              item.classList.remove('dropdown-open');
              var l = item.querySelector('.header-nav__link');
              if (l) l.setAttribute('aria-expanded', 'false');
            }
          });
        }
        parent.classList.toggle('dropdown-open', willOpen);
        this.setAttribute('aria-expanded', String(willOpen));
      }
    });
  });

  // Columns variant: mega heading toggle (mobile)
  document.querySelectorAll('.header-mega__heading--toggle').forEach(function (btn) {
    btn.addEventListener('click', function (e) {
      if (!isMobile()) return;
      e.preventDefault();
      e.stopPropagation();
      var col = this.closest('.header-mega__column');
      if (!col) return;
      var willOpen = !col.classList.contains('is-open');
      var mega = this.closest('.header-mega');
      if (mega) {
        mega.querySelectorAll('.header-mega__column.is-open').forEach(function (other) {
          if (other !== col) {
            other.classList.remove('is-open');
            var b = other.querySelector('.header-mega__heading--toggle');
            if (b) b.setAttribute('aria-expanded', 'false');
          }
        });
      }
      col.classList.toggle('is-open', willOpen);
      this.setAttribute('aria-expanded', String(willOpen));
    });
  });

  // Grid variant: left nav item toggles its grid panel (works on both desktop and mobile,
  // but mobile uses click-only since hover doesn't apply)
  document.querySelectorAll('.header-nav__item.has-mega--grid').forEach(function (item) {
    var navItems = item.querySelectorAll('.header-mega__nav-item');
    var panels = item.querySelectorAll('.header-mega__grid-panel');

    navItems.forEach(function (navItem, i) {
      // Desktop hover behavior
      navItem.addEventListener('mouseenter', function () {
        if (isMobile()) return;
        navItems.forEach(function (n) { n.classList.remove('is-active'); });
        panels.forEach(function (p) { p.classList.remove('is-active'); });
        navItem.classList.add('is-active');
        if (panels[i]) panels[i].classList.add('is-active');
      });

      // Mobile click toggle (only button-style toggles)
      if (navItem.classList.contains('header-mega__nav-item--toggle')) {
        navItem.addEventListener('click', function (e) {
          if (!isMobile()) return;
          e.preventDefault();
          e.stopPropagation();
          var willOpen = !navItem.classList.contains('is-open');
          navItems.forEach(function (n) {
            n.classList.remove('is-open');
            if (n.hasAttribute('aria-expanded')) n.setAttribute('aria-expanded', 'false');
          });
          panels.forEach(function (p) { p.classList.remove('is-open'); });
          if (willOpen) {
            navItem.classList.add('is-open');
            navItem.setAttribute('aria-expanded', 'true');
            if (panels[i]) panels[i].classList.add('is-open');
          }
        });
      }
    });
  });

  // Close drawer when a leaf link is tapped
  if (drawer) {
    drawer.addEventListener('click', function (e) {
      if (!isMobile()) return;
      var target = e.target.closest('a');
      if (!target) return;
      // only close on real navigation links
      if (target.getAttribute('href') && target.getAttribute('href') !== '#') {
        closeMenu();
      }
    });
  }

  // close on escape
  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape' && drawer && drawer.classList.contains('is-open')) closeMenu();
  });

  // reset state when resizing past breakpoint
  var resizeTimer;
  window.addEventListener('resize', function () {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(function () { if (!isMobile()) closeMenu(); }, 150);
  });

  setupBackRows();
})();
{% endjavascript %}

{% stylesheet %}
.site-header { width: 100%; position: sticky; top: 0; z-index: 100; }
.header-top { background-color: var(--color-white); border-bottom: 1px solid var(--color-gray-200); }
.header-top__inner {
  max-width: var(--container-max-width, 1400px);
  margin: 0 auto;
  padding: 0.85rem 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1.5rem;
}
.header-top__logo { flex: 0 0 auto; text-align: center; }
.header-top__logo a { text-decoration: none; color: var(--color-black); display: inline-block; }
.header-logo-text {
  font-family: var(--font-display);
  font-size: 1.85rem;
  font-weight: 600;
  letter-spacing: 0.02em;
  line-height: 1.1;
  display: block;
}
.header-logo-img { max-height: 50px; width: auto; }
.header-top__actions { flex: 0 1 320px; display: flex; align-items: center; justify-content: flex-end; gap: 1.25rem; }
.header-action {
  display: flex;
  align-items: center;
  gap: 0.35rem;
  text-decoration: none;
  color: var(--color-black);
  font-family: var(--font-body);
  font-size: var(--text-sm);
  font-weight: 500;
  white-space: nowrap;
  transition: color var(--transition-fast);
}
.header-action:hover { color: var(--color-gray-600); }
.header-action__icon { display: flex; align-items: center; }
.header-action__icon svg { width: 1.25rem; height: 1.25rem; }
.header-action--cart {
  position: relative;
  border: 1px solid var(--color-gray-200);
  padding: 4px;
  border-radius: 0.5rem;
  transition: all 0.3s ease;
}
.header-action--cart:hover { border-color: var(--color-gray-300); background-color: var(--color-gray-100); }
.header-cart-count {
  position: absolute;
  top: -6px;
  right: -8px;
  background: var(--color-black);
  color: var(--color-white);
  font-family: var(--font-body);
  font-size: 0.6rem;
  font-weight: 700;
  width: 1.1rem;
  height: 1.1rem;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
}

.header-nav { background-color: var(--color-black); position: relative; }
.header-nav__inner {
  max-width: var(--container-max-width, 1400px);
  margin: 0 auto;
  padding: 0 var(--container-padding, 60px);
  display: flex;
  align-items: center;
  justify-content: center;
}
.header-nav__list { list-style: none; padding: 0; margin: 0; display: flex; align-items: center; gap: 0; }
.header-nav__item { position: relative; }
.header-nav__link {
  display: flex;
  align-items: center;
  gap: 0.3rem;
  padding: 0.85rem 1.1rem;
  color: var(--color-white);
  font-family: var(--font-body);
  font-size: var(--text-xs);
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  text-decoration: none;
  white-space: nowrap;
  transition: background-color var(--transition-fast);
  background: none;
  border: none;
  cursor: pointer;
}
.header-nav__link:hover { background-color: var(--color-gray-800); }
.header-nav__chevron { display: flex; align-items: center; }
.header-nav__chevron svg { width: 0.65rem; height: 0.65rem; transition: transform var(--transition-fast); }

.header-nav__dropdown {
  display: none;
  position: absolute;
  top: 100%;
  left: 0;
  min-width: 220px;
  background: var(--color-white);
  border: 1px solid var(--color-gray-200);
  list-style: none;
  padding: 0.5rem 0;
  margin: 0;
  z-index: 200;
}
@media (hover: hover) {
  .header-nav__item.has-dropdown:not(.has-mega):hover .header-nav__dropdown { display: block; }
  .header-nav__item.has-dropdown:hover .header-nav__chevron svg { transform: rotate(180deg); }
}
.header-nav__dropdown-link {
  display: block;
  padding: 0.6rem 1.25rem;
  color: var(--color-black);
  text-decoration: none;
  font-family: var(--font-body);
  font-size: var(--text-sm);
  transition: background-color var(--transition-fast);
}
.header-nav__dropdown-link:hover { background-color: var(--color-gray-100); }

.header-nav__item.has-mega { position: static; }
.header-mega {
  display: none;
  position: absolute;
  top: 100%;
  left: 0;
  right: 0;
  width: 100%;
  background: var(--color-white);
  border-top: 1px solid var(--color-gray-200);
  border-bottom: 2px solid var(--color-black);
  z-index: 200;
  padding: 2.5rem 0;
}
@media (hover: hover) {
  .header-nav__item.has-mega:hover .header-mega { display: block; }
}
.header-mega__inner {
  max-width: var(--container-max-width, 1400px);
  margin: 0 auto;
  padding: 0 var(--container-padding, 60px);
  display: flex;
  gap: 3rem;
}
.header-mega__column { flex: 1; min-width: 0; }
.header-mega__heading {
  display: block;
  font-family: var(--font-body);
  font-size: var(--text-sm);
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: var(--color-black);
  text-decoration: none;
  padding-bottom: 0.75rem;
  margin-bottom: 0.75rem;
  border-bottom: 1px solid var(--color-gray-200);
  transition: color var(--transition-fast);
}
.header-mega__heading:hover { color: var(--color-gray-600); }
.header-mega__heading--toggle {
  background: none;
  border: none;
  cursor: pointer;
  text-align: left;
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 0.5rem;
}
.header-mega__heading-chevron { display: none; }
.header-mega__list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.15rem; }
.header-mega__link {
  display: block;
  padding: 0.4rem 0;
  font-family: var(--font-body);
  font-size: var(--text-sm);
  color: var(--color-gray-600);
  text-decoration: none;
  transition: color var(--transition-fast);
}
.header-mega__link:hover { color: var(--color-black); }

.header-mega--grid .header-mega__inner--grid { display: flex; gap: 3rem; align-items: flex-start; }
.header-mega__nav { flex: 0 0 220px; display: flex; flex-direction: column; gap: 0; }
.header-mega__nav-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0.75rem 0;
  font-family: var(--font-body);
  font-size: var(--text-sm);
  font-weight: 500;
  color: var(--color-black);
  text-decoration: none;
  border-bottom: 1px solid var(--color-gray-200);
  transition: background-color var(--transition-fast), color var(--transition-fast);
}
.header-mega__nav-item:hover,
.header-mega__nav-item.is-active { background-color: var(--color-gray-100); color: var(--color-black); }
.header-mega__nav-item--toggle {
  background: none;
  border: none;
  border-bottom: 1px solid var(--color-gray-200);
  cursor: pointer;
  text-align: left;
  width: 100%;
}
.header-mega__nav-chevron { display: flex; opacity: 0.5; }
.header-mega__nav-item.is-active .header-mega__nav-chevron { opacity: 1; }
.header-mega__nav-chevron svg { width: 0.6rem; height: 0.6rem; }
.header-mega__grid-wrap { flex: 1; min-width: 0; position: relative; }
.header-mega__grid-panel { display: none; }
.header-mega__grid-panel.is-active { display: block; }
.header-mega__grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.5rem; }
.header-mega__grid-item { text-decoration: none; color: inherit; transition: opacity var(--transition-fast); }
.header-mega__grid-item:hover { opacity: 0.85; }
.header-mega__grid-image { aspect-ratio: 1; overflow: hidden; background: var(--color-gray-100); margin-bottom: 0.5rem; }
.header-mega__grid-image img { width: 100%; height: 100%; object-fit: cover; }
.header-mega__grid-label {
  display: block;
  font-family: var(--font-body);
  font-size: var(--text-sm);
  font-weight: 500;
  color: var(--color-black);
  text-align: center;
}

.header-mega--columns .header-mega__inner { display: grid; grid-template-columns: repeat(4, 1fr); gap: 2rem; }
.header-mega__heading--static { pointer-events: none; cursor: default; }
.header-mega__products { grid-column: span 1; }
.header-mega__product-grid { display: flex; flex-direction: column; gap: 1rem; }
.header-mega__product-card {
  display: flex;
  align-items: center;
  gap: 1rem;
  text-decoration: none;
  color: inherit;
  transition: background-color var(--transition-fast);
  padding: 0.25rem 0;
}
.header-mega__product-card:hover { background-color: transparent; }
.header-mega__product-image {
  flex: 0 0 64px;
  width: 64px;
  height: 64px;
  overflow: hidden;
  background: var(--color-gray-100);
  position: relative;
}
.header-mega__product-image img { width: 100%; height: 100%; object-fit: cover; }
.header-mega__product-badge {
  position: absolute;
  top: 4px;
  right: 4px;
  background: var(--color-black);
  color: var(--color-white);
  font-size: 0.6rem;
  font-weight: 700;
  padding: 2px 6px;
  border-radius: 0;
}
.header-mega__product-title { flex: 1; font-family: var(--font-body); font-size: var(--text-sm); color: var(--color-black); line-height: 1.3; }
.header-mega__product-price { font-family: var(--font-body); font-size: var(--text-sm); font-weight: 600; color: var(--color-black); }

.header-nav__item--sale { margin-left: 0.5rem; }
.header-nav__sale-btn {
  display: inline-block;
  padding: 0.4rem 1.25rem;
  background-color: var(--color-white);
  color: var(--color-black);
  font-family: var(--font-body);
  font-size: var(--text-xs);
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  text-decoration: none;
  border-radius: 0;
  transition: background-color var(--transition-fast), color var(--transition-fast);
  white-space: nowrap;
}
.header-nav__sale-btn:hover { background-color: var(--color-gray-200); }

.header-nav__mobile-toggle {
  display: none;
  flex-direction: column;
  gap: 4px;
  background: none;
  border: none;
  cursor: pointer;
  padding: 0.5rem;
}
.header-nav__mobile-toggle span {
  display: block;
  width: 22px;
  height: 2px;
  background: var(--color-white);
  border-radius: 0;
  transition: transform 0.25s, opacity 0.25s;
}
.header-nav__mobile-toggle.is-active span:nth-child(1) { transform: translateY(6px) rotate(45deg); }
.header-nav__mobile-toggle.is-active span:nth-child(2) { opacity: 0; }
.header-nav__mobile-toggle.is-active span:nth-child(3) { transform: translateY(-6px) rotate(-45deg); }

.header-nav__drawer { display: contents; }
.header-nav__drawer-head { display: none; }
.header-nav__backdrop { display: none; }
.header-nav__back-row { display: none; }

@media (max-width: 899px) {
  .header-top__inner {
    flex-wrap: wrap;
    gap: 0.75rem;
    padding-left: var(--container-padding-tablet, 24px);
    padding-right: var(--container-padding-tablet, 24px);
  }
  .header-top__search { order: 3; flex: 1 1 100%; }
  .header-top__logo { order: 1; }
  .header-top__actions { order: 2; flex: 0 0 auto; gap: 0.85rem; }
  .header-action__label { display: none; }
  .header-nav__mobile-toggle { display: flex; }
  .header-nav__inner {
    justify-content: flex-start;
    padding-left: var(--container-padding-tablet, 24px);
    padding-right: var(--container-padding-tablet, 24px);
    min-height: 52px;
  }

  /* Full-height slide-in drawer */
  .header-nav__drawer {
    display: flex;
    flex-direction: column;
    position: fixed;
    top: 0;
    left: 0;
    bottom: 0;
    width: min(420px, 88vw);
    height: 100vh;
    height: 100dvh;
    background: var(--color-black);
    z-index: 1001;
    transform: translateX(-100%);
    transition: transform 0.35s cubic-bezier(0.16, 1, 0.3, 1);
    box-shadow: 8px 0 28px rgba(0, 0, 0, 0.25);
    overscroll-behavior: contain;
    -webkit-overflow-scrolling: touch;
  }
  .header-nav__drawer.is-open { transform: translateX(0); }
  .header-nav__drawer-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1rem 1.25rem;
    border-bottom: 1px solid var(--color-gray-800);
    flex: 0 0 auto;
  }
  .header-nav__drawer-logo {
    display: inline-flex;
    align-items: center;
    color: var(--color-white);
    text-decoration: none;
    font-family: var(--font-display);
    font-size: 1.35rem;
    font-weight: 600;
    letter-spacing: 0.02em;
  }
  .header-nav__drawer-logo-img { max-height: 32px; width: auto; filter: invert(1) brightness(2); }
  .header-nav__drawer-close {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    padding: 0;
    background: none;
    border: 1px solid var(--color-gray-700);
    border-radius: 50%;
    color: var(--color-white);
    cursor: pointer;
    transition: background-color var(--transition-fast), border-color var(--transition-fast);
  }
  .header-nav__drawer-close:hover { background-color: var(--color-gray-800); border-color: var(--color-gray-600); }

  .header-nav__backdrop {
    display: block;
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0, 0, 0, 0.5);
    z-index: 1000;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
  }
  .header-nav__backdrop.is-open { opacity: 1; pointer-events: auto; }

  /* Level 1: base list */
  .header-nav__list {
    display: flex;
    flex-direction: column;
    width: 100%;
    flex: 1 1 auto;
    overflow-y: auto;
    overscroll-behavior: contain;
    -webkit-overflow-scrolling: touch;
    padding: 0.5rem 0 2rem;
    background: var(--color-black);
    position: relative;
  }
  .header-nav__item { width: 100%; border-bottom: 1px solid var(--color-gray-800); position: static; }
  .header-nav__item:last-child { border-bottom: none; }
  .header-nav__link { padding: 1rem 1.25rem; width: 100%; justify-content: space-between; font-size: var(--text-sm); }
  .header-nav__link:hover { background-color: var(--color-gray-800); }
  .header-nav__chevron svg { width: 0.85rem; height: 0.85rem; }

  /* Slide-in sub-panels (level 2 + level 3) */
  .header-nav__dropdown,
  .header-mega,
  .header-mega__grid-panel,
  .header-mega__column.has-sub .header-mega__list {
    display: flex;
    flex-direction: column;
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    width: 100%;
    height: 100%;
    background: var(--color-black);
    border: none;
    padding: 0;
    margin: 0;
    transform: translateX(100%);
    transition: transform 0.32s cubic-bezier(0.16, 1, 0.3, 1);
    overflow-y: auto;
    overscroll-behavior: contain;
    -webkit-overflow-scrolling: touch;
    z-index: 5;
    visibility: hidden;
  }
  .header-nav__dropdown { min-width: 0; }
  .header-mega { width: 100%; }

  /* Level 2 open */
  .header-nav__item.has-dropdown.dropdown-open > .header-nav__dropdown,
  .header-nav__item.has-mega.dropdown-open > .header-mega {
    transform: translateX(0);
    visibility: visible;
  }
  /* Level 3 open (sits above level 2 inside .header-mega) */
  .header-mega__grid-panel.is-open,
  .header-mega__column.is-open .header-mega__list {
    transform: translateX(0);
    visibility: visible;
    z-index: 6;
  }

  /* Inner layouts inside open level-2 mega should fill it */
  .header-mega__inner,
  .header-mega--grid .header-mega__inner--grid {
    display: flex;
    flex-direction: column;
    gap: 0;
    padding: 0;
    width: 100%;
  }
  .header-mega__column { padding: 0; }
  .header-mega__nav { display: flex; flex-direction: column; width: 100%; }
  .header-mega__grid-wrap { display: contents; }

  /* Level-2 list items (drill-down rows) */
  .header-mega__heading,
  .header-mega__heading--toggle,
  .header-mega__nav-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    background: none;
    border: none;
    border-bottom: 1px solid var(--color-gray-800);
    text-align: left;
    cursor: pointer;
    color: var(--color-white);
    padding: 1rem 1.25rem;
    margin: 0;
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 500;
    text-transform: none;
    letter-spacing: 0;
  }
  .header-mega__heading:hover,
  .header-mega__nav-item:hover { background-color: var(--color-gray-800); color: var(--color-white); }
  .header-mega__heading-chevron,
  .header-mega__nav-item .header-mega__nav-chevron {
    display: inline-flex;
    align-items: center;
    opacity: 0.7;
  }
  .header-mega__heading-chevron svg,
  .header-mega__nav-item .header-mega__nav-chevron svg { width: 0.75rem; height: 0.75rem; }

  /* Level-3 content */
  .header-mega__list { padding: 0.5rem 0; background: var(--color-black); }
  .header-mega__link { color: var(--color-gray-300); padding: 0.85rem 1.25rem; font-size: var(--text-sm); }
  .header-mega__link:hover { color: var(--color-white); background-color: var(--color-gray-800); }

  .header-mega__grid { grid-template-columns: repeat(2, 1fr); gap: 0.85rem; padding: 1rem 1.25rem; }
  .header-mega__grid-label { color: var(--color-gray-300); font-size: var(--text-xs); }

  .header-nav__dropdown-link {
    display: block;
    color: var(--color-gray-300);
    padding: 1rem 1.25rem;
    font-size: var(--text-sm);
    border-bottom: 1px solid var(--color-gray-800);
  }
  .header-nav__dropdown-link:hover { background-color: var(--color-gray-800); color: var(--color-white); }

  /* Back row injected at the top of each sub-panel */
  .header-nav__back-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.95rem 1.25rem;
    border-bottom: 1px solid var(--color-gray-800);
    background: var(--color-black);
    position: sticky;
    top: 0;
    z-index: 2;
    flex-shrink: 0;
  }
  .header-nav__back {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: none;
    border: none;
    color: var(--color-white);
    cursor: pointer;
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 600;
    padding: 0;
  }
  .header-nav__back svg { width: 1rem; height: 1rem; }
  .header-nav__back-title {
    color: var(--color-white);
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .header-mega--columns .header-mega__inner { display: flex; flex-direction: column; grid-template-columns: 1fr; gap: 0; }
  .header-mega__products { padding: 0.5rem 2rem 1rem; }
  .header-mega__product-grid { flex-direction: row; flex-wrap: wrap; gap: 0.75rem; }
  .header-mega__product-card { flex: 1 1 calc(50% - 0.5rem); flex-direction: column; align-items: flex-start; }
  .header-mega__product-image { width: 100%; height: auto; aspect-ratio: 1; flex: none; }
  .header-mega__product-title,
  .header-mega__product-price { color: var(--color-gray-300); }
  .header-nav__item--sale { padding: 1rem 1.25rem; margin-left: 0; border-bottom: none; }
  .header-nav__sale-btn { display: block; text-align: center; width: 100%; padding: 0.85rem 1rem; }
}
@media (max-width: 480px) {
  .header-top__inner { padding: 0.7rem var(--container-padding-mobile, 20px); gap: 0.5rem; }
  .header-logo-img { max-height: 38px; }
  .header-logo-text { font-size: 1.4rem; }
  .header-top__actions { gap: 0.6rem; }
  .header-action__icon svg { width: 1.15rem; height: 1.15rem; }
  .header-nav__inner {
    padding-left: var(--container-padding-mobile, 20px);
    padding-right: var(--container-padding-mobile, 20px);
    min-height: 48px;
  }
  .header-mega__grid { gap: 0.75rem; padding: 0.75rem 1rem; }
}
{% endstylesheet %}

{% schema %}
{
  "name": "t:names.header",
  "max_blocks": 10,
  "blocks": [
    {
      "type": "mega_menu",
      "name": "t:names.mega_menu_config",
      "settings": [
        {
          "type": "text",
          "id": "menu_item_title",
          "label": "t:header_settings.menu_item_title",
          "info": "t:header_settings.menu_item_title_info"
        },
        {
          "type": "select",
          "id": "variant",
          "label": "t:header_settings.dropdown_variant",
          "options": [
            { "value": "grid", "label": "t:header_settings.variant_grid" },
            { "value": "columns", "label": "t:header_settings.variant_columns" }
          ],
          "default": "grid"
        },
        {
          "type": "collection",
          "id": "featured_collection",
          "label": "t:header_settings.featured_collection",
          "info": "t:header_settings.featured_collection_info"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "header",
      "content": "t:header_settings.logo"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "t:header_settings.logo_image"
    },
    {
      "type": "header",
      "content": "t:header_settings.navigation"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "t:header_settings.main_menu",
      "default": "main-menu"
    },
    {
      "type": "header",
      "content": "t:header_settings.search"
    },
    {
      "type": "text",
      "id": "search_placeholder",
      "label": "t:header_settings.search_placeholder",
      "default": "What are you looking for?"
    },
    {
      "type": "header",
      "content": "t:header_settings.store_locator"
    },
    {
      "type": "checkbox",
      "id": "show_store_locator",
      "label": "t:header_settings.show_store_locator",
      "default": true
    },
    {
      "type": "url",
      "id": "store_locator_url",
      "label": "t:header_settings.store_locator_url"
    },
    {
      "type": "header",
      "content": "t:header_settings.on_sale_button"
    },
    {
      "type": "checkbox",
      "id": "show_on_sale_link",
      "label": "t:header_settings.show_on_sale",
      "default": true
    },
    {
      "type": "text",
      "id": "on_sale_text",
      "label": "t:header_settings.on_sale_text",
      "default": "On Sale"
    },
    {
      "type": "url",
      "id": "on_sale_url",
      "label": "t:header_settings.on_sale_url"
    }
  ]
}
{% endschema %}
