<footer class="site-footer full-width">
  {%- comment -%} Contact info row {%- endcomment -%}
  <div class="footer-contact">
    <div class="footer-contact__inner">
      <div class="footer-contact__item">
        <span class="footer-contact__icon">{{ 'icon-chat.svg' | inline_asset_content }}</span>
        <div>
          <span class="footer-contact__label">{{ 'footer.customer_service' | t }}</span>
          <span class="footer-contact__text">{{ section.settings.contact_hours | default: 'Mon-Sat, 9am-6pm EST' }}</span>
        </div>
      </div>
      <div class="footer-contact__item">
        <span class="footer-contact__icon">{{ 'icon-phone.svg' | inline_asset_content }}</span>
        <div>
          <span class="footer-contact__label">{{ 'footer.call_us' | t }}</span>
          <a href="tel:{{ section.settings.phone | remove: ' ' | remove: '-' | remove: '(' | remove: ')' }}" class="footer-contact__text footer-contact__link">
            {{ section.settings.phone | default: '+1 888-234-1234 (toll-free)' }}
          </a>
        </div>
      </div>
      <div class="footer-contact__item">
        <span class="footer-contact__icon">{{ 'icon-mail.svg' | inline_asset_content }}</span>
        <div>
          <span class="footer-contact__label">{{ 'footer.get_in_touch' | t }}</span>
          <a href="mailto:{{ section.settings.email }}" class="footer-contact__text footer-contact__link">
            {{ section.settings.email | default: 'touch@example.com' }}
          </a>
        </div>
      </div>
      <div class="footer-contact__item">
        <span class="footer-contact__icon">{{ 'icon-map-pin.svg' | inline_asset_content }}</span>
        <div>
          <span class="footer-contact__label">{{ 'footer.address' | t }}</span>
          <span class="footer-contact__text">{{ section.settings.address | default: '382 NE 191st St #87394 Miami' }}</span>
        </div>
      </div>
    </div>
  </div>

  {%- comment -%} Newsletter + link columns {%- endcomment -%}
  <div class="footer-main">
    <div class="footer-main__inner">
      <div class="footer-newsletter">
        <h3 class="footer-newsletter__title">{{ section.settings.newsletter_heading | default: 'Join Our Newsletter' }}</h3>
        <p class="footer-newsletter__text">{{ section.settings.newsletter_text | default: 'Sign up to our newsletter & receive 10% off your first order.' }}</p>
        {% form 'customer', class: 'footer-newsletter__form' %}
          {% if form.posted_successfully? %}
            <p class="footer-newsletter__success">{{ 'footer.subscribe_success' | t }}</p>
          {% else %}
            <input type="hidden" name="contact[tags]" value="newsletter">
            <input
              type="email"
              name="contact[email]"
              class="footer-newsletter__input"
              placeholder="{{ section.settings.newsletter_placeholder | default: 'Enter your email' }}"
              required
            >
            <button type="submit" class="footer-newsletter__btn btn btn-primary--light">
              {{ section.settings.newsletter_btn | default: 'Sign Up' }}
            </button>
          {% endif %}
          <p class="footer-newsletter__consent">
            {{ section.settings.newsletter_consent | default: 'By subscribing you agree to the' }}
            <a href="{{ section.settings.terms_url | default: '/policies/terms-of-service' }}">{{ 'footer.terms_of_use' | t }}</a>
            &amp;
            <a href="{{ section.settings.privacy_url | default: '/policies/privacy-policy' }}">{{ 'footer.privacy_policy' | t }}</a>.
          </p>
        {% endform %}
      </div>

      <div class="footer-links">
        {%- assign menu_company = linklists[section.settings.menu_company] -%}
        {% if menu_company and menu_company.links.size > 0 %}
          <div class="footer-links__col">
            <h4 class="footer-links__title">{{ menu_company.title | default: 'Company' }}</h4>
            <ul class="footer-links__list">
              {% for link in menu_company.links %}
                <li><a href="{{ link.url }}">{{ link.title }}</a></li>
              {% endfor %}
            </ul>
          </div>
        {% endif %}
        {%- assign menu_collection = linklists[section.settings.menu_collection] -%}
        {% if menu_collection and menu_collection.links.size > 0 %}
          <div class="footer-links__col">
            <h4 class="footer-links__title">{{ menu_collection.title | default: 'Collection' }}</h4>
            <ul class="footer-links__list">
              {% for link in menu_collection.links %}
                <li><a href="{{ link.url }}">{{ link.title }}</a></li>
              {% endfor %}
            </ul>
          </div>
        {% endif %}
        {%- assign menu_shop = linklists[section.settings.menu_shop] -%}
        {% if menu_shop and menu_shop.links.size > 0 %}
          <div class="footer-links__col">
            <h4 class="footer-links__title">{{ menu_shop.title | default: 'Shop' }}</h4>
            <ul class="footer-links__list">
              {% for link in menu_shop.links %}
                <li><a href="{{ link.url }}">{{ link.title }}</a></li>
              {% endfor %}
            </ul>
          </div>
        {% endif %}
      </div>
    </div>
  </div>

  {%- comment -%} Bottom bar: locale, copyright, social, legal {%- endcomment -%}
  <div class="footer-bottom">
    <div class="footer-bottom__inner">
      <div class="footer-bottom__left">
        {% form 'localization', class: 'footer-locale' %}
          {% if form.available_currencies.size > 1 %}
            <div class="footer-locale__select">
              <label for="footer-currency-{{ section.id }}" class="sr-only">{{ 'footer.currency_label' | t }}</label>
              <select id="footer-currency-{{ section.id }}" name="currency" class="footer-locale__select-input">
                {% for currency in form.available_currencies %}
                  <option value="{{ currency.iso_code }}" {% if currency.iso_code == form.current_currency.iso_code %}selected{% endif %}>
                    {{ currency.iso_code }} ({{ currency.symbol }})
                  </option>
                {% endfor %}
              </select>
              <button type="submit" class="sr-only">{{ 'footer.update_currency' | t }}</button>
            </div>
          {% endif %}
        {% endform %}
        <p class="footer-copyright">
          &copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. {{ powered_by_link }}
        </p>
      </div>
      <div class="footer-bottom__right">
        {% if section.settings.show_social %}
          <div class="footer-social">
            {% if section.settings.social_facebook != blank %}
              <a href="{{ section.settings.social_facebook }}" target="_blank" rel="noopener" aria-label="{{ 'footer.social.facebook' | t }}">{{ 'icon-facebook.svg' | inline_asset_content }}</a>
            {% endif %}
            {% if section.settings.social_x != blank %}
              <a href="{{ section.settings.social_x }}" target="_blank" rel="noopener" aria-label="{{ 'footer.social.x' | t }}">{{ 'icon-x.svg' | inline_asset_content }}</a>
            {% endif %}
            {% if section.settings.social_instagram != blank %}
              <a href="{{ section.settings.social_instagram }}" target="_blank" rel="noopener" aria-label="{{ 'footer.social.instagram' | t }}">{{ 'icon-instagram.svg' | inline_asset_content }}</a>
            {% endif %}
            {% if section.settings.social_tiktok != blank %}
              <a href="{{ section.settings.social_tiktok }}" target="_blank" rel="noopener" aria-label="{{ 'footer.social.tiktok' | t }}">{{ 'icon-tiktok.svg' | inline_asset_content }}</a>
            {% endif %}
          </div>
        {% endif %}
        <div class="footer-legal">
          <a href="{{ section.settings.terms_url | default: '/policies/terms-of-service' }}">{{ 'footer.terms_of_service' | t }}</a>
          <a href="{{ section.settings.privacy_url | default: '/policies/privacy-policy' }}">{{ 'footer.privacy_policy' | t }}</a>
        </div>
      </div>
    </div>
  </div>
</footer>

{% javascript %}
(function () {
  var form = document.querySelector('.site-footer .footer-locale form');
  var select = form && form.querySelector('select[name="currency"]');
  if (form && select) {
    select.addEventListener('change', function () { form.submit(); });
  }
})();
{% endjavascript %}

{% stylesheet %}
.site-footer { background-color: var(--color-black); color: var(--color-white); }
.footer-contact { border-bottom: 1px solid var(--color-gray-800); }
.footer-contact__inner {
  max-width: var(--container-max-width, 1400px);
  margin: 0 auto;
  padding: 2rem var(--container-padding, 60px);
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 2rem;
}
.footer-contact__item { display: flex; gap: 1rem; align-items: flex-start; }
.footer-contact__icon { flex-shrink: 0; display: flex; align-items: center; color: var(--color-gray-400); }
.footer-contact__icon svg { width: 1.25rem; height: 1.25rem; }
.footer-contact__label {
  display: block;
  font-family: var(--font-body);
  font-size: var(--text-xs);
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: var(--color-gray-400);
  margin-bottom: 0.25rem;
}
.footer-contact__text { font-family: var(--font-body); font-size: var(--text-sm); color: var(--color-white); }
.footer-contact__link { color: var(--color-white); text-decoration: none; transition: color var(--transition-fast); }
.footer-contact__link:hover { color: var(--color-gray-400); }

.footer-main { padding: 3rem 0; }
.footer-main__inner {
  max-width: var(--container-max-width, 1400px);
  margin: 0 auto;
  padding: 0 var(--container-padding, 60px);
  display: grid;
  grid-template-columns: 1fr 1.5fr;
  gap: 4rem;
  align-items: start;
}
.footer-newsletter__title {
  font-family: var(--font-display);
  font-size: var(--text-2xl);
  font-weight: 500;
  color: var(--color-white);
  margin-bottom: 0.5rem;
}
.footer-newsletter__text {
  font-family: var(--font-body);
  font-size: var(--text-sm);
  color: var(--color-gray-400);
  margin-bottom: 1.5rem;
  line-height: 1.5;
}
.footer-newsletter__success { font-family: var(--font-body); font-size: var(--text-sm); color: var(--color-white); margin-bottom: 1rem; }
.footer-newsletter__form { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 1rem; }
.footer-newsletter__input {
  flex: 1;
  min-width: 200px;
  padding: 0.75rem 1rem;
  font-family: var(--font-body);
  font-size: var(--text-sm);
  color: var(--color-white);
  background: var(--color-gray-800);
  border: 1px solid var(--color-gray-700);
  outline: none;
  transition: border-color var(--transition-fast);
}
.footer-newsletter__input::placeholder { color: var(--color-gray-500); }
.footer-newsletter__input:focus { border-color: var(--color-gray-500); }
.footer-newsletter__btn { padding: 0.75rem 1.5rem; white-space: nowrap; }
.footer-newsletter__consent { font-family: var(--font-body); font-size: var(--text-xs); color: var(--color-gray-500); line-height: 1.5; }
.footer-newsletter__consent a { color: var(--color-gray-400); text-decoration: underline; transition: color var(--transition-fast); }
.footer-newsletter__consent a:hover { color: var(--color-white); }

.footer-links { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2rem; }
.footer-links__title {
  font-family: var(--font-body);
  font-size: var(--text-sm);
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: var(--color-white);
  margin-bottom: 1rem;
}
.footer-links__list { list-style: none; padding: 0; margin: 0; }
.footer-links__list li { margin-bottom: 0.5rem; }
.footer-links__list a {
  font-family: var(--font-body);
  font-size: var(--text-sm);
  color: var(--color-gray-400);
  text-decoration: none;
  transition: color var(--transition-fast);
}
.footer-links__list a:hover { color: var(--color-white); }

.footer-bottom { background-color: var(--color-gray-900); border-top: 1px solid var(--color-gray-800); }
.footer-bottom__inner {
  max-width: var(--container-max-width, 1400px);
  margin: 0 auto;
  padding: 1.25rem var(--container-padding, 60px);
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  align-items: center;
  gap: 1rem;
}
.footer-bottom__left { display: flex; flex-wrap: wrap; align-items: center; gap: 1.5rem; }
.footer-locale__select-input {
  padding: 0.4rem 0.75rem;
  font-family: var(--font-body);
  font-size: var(--text-sm);
  color: var(--color-white);
  background: var(--color-gray-800);
  border: 1px solid var(--color-gray-700);
  cursor: pointer;
}
.footer-locale__select-input option { background: var(--color-black); color: var(--color-white); }
.footer-copyright { font-family: var(--font-body); font-size: var(--text-sm); color: var(--color-gray-500); }
.footer-copyright a { color: var(--color-gray-500); text-decoration: none; }
.footer-copyright a:hover { color: var(--color-gray-400); }
.footer-bottom__right { display: flex; flex-wrap: wrap; align-items: center; gap: 1.5rem; }
.footer-social { display: flex; gap: 1rem; }
.footer-social a {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 2rem;
  height: 2rem;
  color: var(--color-white);
  border: 1px solid var(--color-gray-600);
  border-radius: 50%;
  transition: border-color var(--transition-fast), color var(--transition-fast);
}
.footer-social a:hover { border-color: var(--color-white); color: var(--color-white); }
.footer-social svg { width: 1rem; height: 1rem; }
.footer-legal { display: flex; gap: 1rem; }
.footer-legal a {
  font-family: var(--font-body);
  font-size: var(--text-sm);
  color: var(--color-gray-500);
  text-decoration: none;
  transition: color var(--transition-fast);
}
.footer-legal a:hover { color: var(--color-white); }

@media (max-width: 992px) {
  .footer-contact__inner {
    grid-template-columns: repeat(2, 1fr);
    padding-left: var(--container-padding-tablet, 24px);
    padding-right: var(--container-padding-tablet, 24px);
  }
  .footer-main__inner {
    grid-template-columns: 1fr;
    padding-left: var(--container-padding-tablet, 24px);
    padding-right: var(--container-padding-tablet, 24px);
  }
  .footer-links { grid-template-columns: repeat(3, 1fr); }
  .footer-bottom__inner {
    padding-left: var(--container-padding-tablet, 24px);
    padding-right: var(--container-padding-tablet, 24px);
  }
}
@media (max-width: 768px) {
  .footer-contact__inner { grid-template-columns: 1fr; gap: 1.5rem; padding: 1.5rem var(--container-padding-tablet, 24px); }
  .footer-main { padding: 2rem 0; }
  .footer-links { grid-template-columns: 1fr; gap: 1.5rem; }
  .footer-newsletter__form { flex-direction: column; }
  .footer-newsletter__input { min-width: 100%; }
  .footer-bottom__inner { flex-direction: column; align-items: flex-start; padding: 1rem var(--container-padding-tablet, 24px); }
  .footer-bottom__left { flex-direction: column; align-items: flex-start; }
  .footer-bottom__right { flex-direction: column; align-items: flex-start; }
}
{% endstylesheet %}

{% schema %}
{
  "name": "t:names.footer",
  "settings": [
    {
      "type": "header",
      "content": "t:footer_settings.contact_information"
    },
    {
      "type": "text",
      "id": "contact_hours",
      "label": "t:footer_settings.customer_hours",
      "default": "Mon-Sat, 9am-6pm EST"
    },
    {
      "type": "text",
      "id": "phone",
      "label": "t:footer_settings.phone",
      "default": "+1 888-234-1234 (toll-free)"
    },
    {
      "type": "text",
      "id": "email",
      "label": "t:footer_settings.email",
      "default": "touch@example.com"
    },
    {
      "type": "textarea",
      "id": "address",
      "label": "t:footer_settings.address",
      "default": "382 NE 191st St #87394 Miami"
    },
    {
      "type": "header",
      "content": "t:footer_settings.newsletter"
    },
    {
      "type": "text",
      "id": "newsletter_heading",
      "label": "t:labels.heading",
      "default": "Join Our Newsletter"
    },
    {
      "type": "text",
      "id": "newsletter_text",
      "label": "t:footer_settings.description",
      "default": "Sign up to our newsletter & receive 10% off your first order."
    },
    {
      "type": "text",
      "id": "newsletter_placeholder",
      "label": "t:footer_settings.email_placeholder",
      "default": "Enter your email"
    },
    {
      "type": "text",
      "id": "newsletter_btn",
      "label": "t:footer_settings.button_text",
      "default": "Sign Up"
    },
    {
      "type": "text",
      "id": "newsletter_consent",
      "label": "t:footer_settings.consent_text",
      "default": "By subscribing you agree to the"
    },
    {
      "type": "header",
      "content": "t:footer_settings.link_menus"
    },
    {
      "type": "link_list",
      "id": "menu_company",
      "label": "t:footer_settings.company_menu"
    },
    {
      "type": "link_list",
      "id": "menu_collection",
      "label": "t:footer_settings.collection_menu"
    },
    {
      "type": "link_list",
      "id": "menu_shop",
      "label": "t:footer_settings.shop_menu"
    },
    {
      "type": "header",
      "content": "t:footer_settings.social_links"
    },
    {
      "type": "checkbox",
      "id": "show_social",
      "label": "t:footer_settings.show_social",
      "default": true
    },
    {
      "type": "url",
      "id": "social_facebook",
      "label": "t:footer_settings.facebook_url"
    },
    {
      "type": "url",
      "id": "social_x",
      "label": "t:footer_settings.x_url"
    },
    {
      "type": "url",
      "id": "social_instagram",
      "label": "t:footer_settings.instagram_url"
    },
    {
      "type": "url",
      "id": "social_tiktok",
      "label": "t:footer_settings.tiktok_url"
    },
    {
      "type": "header",
      "content": "t:footer_settings.legal"
    },
    {
      "type": "url",
      "id": "terms_url",
      "label": "t:footer_settings.terms_url"
    },
    {
      "type": "url",
      "id": "privacy_url",
      "label": "t:footer_settings.privacy_url"
    }
  ]
}
{% endschema %}
