{% comment %}
  FAQ section.

  Data source: merchant creates a `faq` metaobject definition in
  Admin → Settings → Custom data with the following fields:
    - question (Single line text)
    - answer   (Rich text or Multi-line text)

  Then on each page, the merchant uses this section and picks which
  FAQ entries to show via the metaobject list setting.
{% endcomment %}

{%- liquid
  assign faqs = section.settings.faqs
  assign max_to_show = section.settings.max_to_show | default: 0
  assign total = faqs.size

  assign limit = total
  if max_to_show > 0 and max_to_show < total
    assign limit = max_to_show
  endif

  assign show_view_all = false
  if section.settings.view_all_url != blank
    assign show_view_all = true
  endif
-%}

<section
  class="faq"
  aria-label="{{ 'faq.aria_label' | t }}"
  data-close-others="{{ section.settings.close_others }}"
  {{ section.shopify_attributes }}
>
  <div class="container">
    {%- if section.settings.heading != blank or section.settings.description != blank -%}
      <header class="faq__header" style="--align: {{ section.settings.text_alignment }};">
        {%- if section.settings.heading != blank -%}
          <h2 class="faq__heading">{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.description != blank -%}
          <div class="faq__description rte">{{ section.settings.description }}</div>
        {%- endif -%}
      </header>
    {%- endif -%}

    {%- if total > 0 -%}
      <ul class="faq__list" role="list">
        {%- for faq in faqs limit: limit -%}
          {%- liquid
            assign question = faq.question
            if question == blank
              assign question = faq.system.handle | replace: '-', ' ' | capitalize
            endif

            assign answer = faq.answer
          -%}
          <li class="faq__item">
            <details
              class="faq__details"
              {% if section.settings.first_open and forloop.first %}open{% endif %}
            >
              <summary class="faq__summary">
                <span class="faq__question">{{ question }}</span>
                <span class="faq__icon" aria-hidden="true">
                  <svg viewBox="0 0 16 16" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M4 6l4 4 4-4"/>
                  </svg>
                </span>
              </summary>
              <div class="faq__answer rte">
                {%- if answer.type == 'rich_text_field' -%}
                  {{ answer | metafield_tag }}
                {%- else -%}
                  {{ answer | newline_to_br }}
                {%- endif -%}
              </div>
            </details>
          </li>
        {%- endfor -%}
      </ul>

      {%- if show_view_all -%}
        <div class="faq__actions">
          <a
            href="{{ section.settings.view_all_url }}"
            class="faq__view-all"
          >
            {{ section.settings.view_all_label | default: 'View all FAQs' }}
          </a>
        </div>
      {%- endif -%}
    {%- else -%}
      <p class="faq__empty">{{ 'faq.empty' | t }}</p>
    {%- endif -%}
  </div>
</section>

{% stylesheet %}
  .faq {
    width: 100%;
    padding: 48px 0;
  }

  .faq__header {
    text-align: var(--align, left);
    margin: 0 0 32px;
  }

  .faq__heading {
    margin: 0 0 12px;
    font-size: 1.75rem;
    font-weight: 600;
    line-height: 1.2;
  }

  .faq__description {
    margin: 0 auto;
    font-size: 1rem;
    line-height: 1.6;
    opacity: 0.8;
  }

  .faq__description > *:first-child {
    margin-top: 0;
  }

  .faq__description > *:last-child {
    margin-bottom: 0;
  }

  .faq__list {
    list-style: none;
    margin: 0;
    padding: 0;
    border-top: 1px solid currentColor;
  }

  .faq__item {
    border-bottom: 1px solid currentColor;
  }

  .faq__details {
    width: 100%;
  }

  .faq__summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 20px 0;
    cursor: pointer;
    list-style: none;
    font-size: 1.0625rem;
    font-weight: 500;
    line-height: 1.4;
  }

  .faq__summary::-webkit-details-marker {
    display: none;
  }

  .faq__summary:focus-visible {
    outline: 2px solid currentColor;
    outline-offset: 2px;
  }

  .faq__icon {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.25s ease;
  }

  .faq__details[open] .faq__icon {
    transform: rotate(180deg);
  }

  .faq__answer {
    padding: 0 0 20px;
    font-size: 0.9375rem;
    line-height: 1.6;
  }

  .faq__answer > *:first-child {
    margin-top: 0;
  }

  .faq__answer > *:last-child {
    margin-bottom: 0;
  }

  .faq__actions {
    display: flex;
    justify-content: center;
    margin-top: 24px;
  }

  .faq__view-all {
    display: inline-block;
    border: 1px solid currentColor;
    color: inherit;
    padding: 12px 28px;
    font-weight: 500;
    text-decoration: none;
    transition: background-color 0.2s ease, color 0.2s ease;
  }

  .faq__view-all:hover,
  .faq__view-all:focus-visible {
    background: currentColor;
    color: var(--color-background, #fff);
    mix-blend-mode: difference;
  }

  .faq__view-all:focus-visible {
    outline: 2px solid currentColor;
    outline-offset: 2px;
  }

  .faq__empty {
    padding: 24px 0;
    opacity: 0.7;
  }

  @media (min-width: 750px) {
    .faq {
      padding: 64px 0;
    }

    .faq__heading {
      font-size: 2.125rem;
    }

    .faq__summary {
      padding: 24px 0;
      font-size: 1.125rem;
    }
  }
{% endstylesheet %}

{% javascript %}
  (function () {
    const sections = document.querySelectorAll('.faq');
    sections.forEach((section) => {
      const items = section.querySelectorAll('.faq__details');
      const closeOthers = section.dataset.closeOthers === 'true';
      if (!closeOthers) return;
      items.forEach((item) => {
        item.addEventListener('toggle', () => {
          if (!item.open) return;
          items.forEach((other) => {
            if (other !== item && other.open) other.open = false;
          });
        });
      });
    });
  })();
{% endjavascript %}

{% schema %}
{
  "name": "t:faq.name",
  "tag": "section",
  "class": "section-faq",
  "settings": [
    {
      "type": "paragraph",
      "content": "t:faq.info_setup"
    },
    {
      "type": "header",
      "content": "t:faq.header_content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.heading",
      "default": "Frequently asked questions"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "t:faq.label_description"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "t:labels.alignment",
      "default": "left",
      "options": [
        { "value": "left", "label": "t:options.alignment.left" },
        { "value": "center", "label": "t:options.alignment.center" },
        { "value": "right", "label": "t:options.alignment.right" }
      ]
    },
    {
      "type": "header",
      "content": "t:faq.header_faqs"
    },
    {
      "type": "metaobject_list",
      "id": "faqs",
      "label": "t:faq.label_faqs",
      "metaobject_type": "faq",
      "limit": 50
    },
    {
      "type": "checkbox",
      "id": "first_open",
      "label": "t:faq.label_first_open",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "close_others",
      "label": "t:faq.label_close_others",
      "default": true,
      "info": "t:faq.info_close_others"
    },
    {
      "type": "header",
      "content": "t:faq.header_view_all"
    },
    {
      "type": "range",
      "id": "max_to_show",
      "label": "t:faq.label_max_to_show",
      "info": "t:faq.info_max_to_show",
      "min": 0,
      "max": 20,
      "step": 1,
      "default": 0
    },
    {
      "type": "url",
      "id": "view_all_url",
      "label": "t:faq.label_view_all_url",
      "info": "t:faq.info_view_all_url"
    },
    {
      "type": "text",
      "id": "view_all_label",
      "label": "t:faq.label_view_all_label",
      "default": "View all FAQs"
    }
  ],
  "presets": [
    {
      "name": "t:faq.name"
    }
  ],
  "enabled_on": {
    "templates": ["*"]
  }
}
{% endschema %}
