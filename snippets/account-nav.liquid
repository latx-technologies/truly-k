{% doc %}
  Renders the sidebar navigation for customer account pages.

  Highlights the active page based on @param `active`.

  @param {string} [active] - One of: "dashboard", "addresses". Determines which nav item is marked current.

  @example
  {% render 'account-nav', active: 'dashboard' %}
{% enddoc %}

<nav class="account-nav" aria-label="{{ 'customer.account.title' | t }}">
  <div class="account-nav__identity">
    <span class="account-nav__eyebrow text-label">{{ 'customer.account.title' | t }}</span>
    {%- if customer.name != blank -%}
      <p class="account-nav__name">{{ customer.name }}</p>
    {%- endif -%}
    {%- if customer.email != blank -%}
      <p class="account-nav__email">{{ customer.email }}</p>
    {%- endif -%}
  </div>

  <ul class="account-nav__list">
    <li>
      <a
        href="{{ routes.account_url }}"
        class="account-nav__link{% if active == 'dashboard' %} account-nav__link--active{% endif %}"
        {% if active == 'dashboard' %}aria-current="page"{% endif %}
      >
        {{ 'customer.account.nav_overview' | t }}
      </a>
    </li>
    <li>
      <a
        href="{{ routes.account_addresses_url }}"
        class="account-nav__link{% if active == 'addresses' %} account-nav__link--active{% endif %}"
        {% if active == 'addresses' %}aria-current="page"{% endif %}
      >
        {{ 'customer.account.nav_addresses' | t }}
      </a>
    </li>
    <li>
      <a href="{{ routes.account_logout_url }}" class="account-nav__link account-nav__link--muted">
        {{ 'customer.account.logout' | t }}
      </a>
    </li>
  </ul>
</nav>

{% stylesheet %}
  .account-nav {
    display: flex;
    flex-direction: column;
    gap: 28px;
    padding: 32px;
    border: 1px solid var(--color-gray-200);
    background: var(--color-white);
  }

  .account-nav__identity {
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding-bottom: 24px;
    border-bottom: 1px solid var(--color-gray-200);
  }

  .account-nav__eyebrow {
    margin: 0;
  }

  .account-nav__name {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-weight: 500;
    color: var(--color-black);
    margin: 0;
    line-height: 1.2;
  }

  .account-nav__email {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--color-gray-500);
    margin: 0;
    word-break: break-word;
  }

  .account-nav__list {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .account-nav__link {
    display: block;
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-gray-600);
    padding: 12px 0;
    border-bottom: 1px solid transparent;
    transition: color var(--transition-fast), border-color var(--transition-fast);
  }

  .account-nav__link:hover {
    color: var(--color-black);
  }

  .account-nav__link--active {
    color: var(--color-black);
    border-bottom-color: var(--color-black);
  }

  .account-nav__link--muted {
    color: var(--color-gray-500);
    margin-top: 12px;
    border-top: 1px solid var(--color-gray-200);
    padding-top: 16px;
  }

  @media (max-width: 900px) {
    .account-nav {
      padding: 24px;
      gap: 20px;
    }
    .account-nav__identity {
      padding-bottom: 16px;
    }
  }
{% endstylesheet %}
