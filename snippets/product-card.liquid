{% doc %}
  Renders a clean product card: image, optional badges, type, title, prices.
  Used in collection grids, search results, related products, etc.

  @param {product} product - The product to render
  @param {string} [aspect] - Image aspect ratio class: "pc-aspect--square", "pc-aspect--portrait", "pc-aspect--landscape". Defaults to portrait.
  @param {boolean} [show_type] - Show product.type meta above title. Defaults to true.
  @param {boolean} [show_vendor] - Show product.vendor instead of type. Defaults to false.
  @param {string} [loading] - Image loading strategy: "eager" or "lazy". Defaults to "lazy".

  @example
  {% render 'product-card', product: product %}
  {% render 'product-card', product: product, aspect: 'pc-aspect--square', show_vendor: true %}
{% enddoc %}

{%- liquid
  assign card_aspect = aspect | default: 'pc-aspect--portrait'
  assign card_loading = loading | default: 'lazy'

  assign on_sale = false
  if product.compare_at_price > product.price
    assign on_sale = true
  endif

  assign sold_out = false
  if product.available == false
    assign sold_out = true
  endif

  assign primary_image = product.featured_image
  assign secondary_image = nil
  if product.images.size > 1
    assign secondary_image = product.images[1]
  endif

  assign show_type_meta = true
  if show_type == false
    assign show_type_meta = false
  endif
-%}

<article class="product-card" data-product-id="{{ product.id }}">
  <a href="{{ product.url }}" class="product-card__media-link">
    <div class="product-card__media {{ card_aspect }}">
      {%- if primary_image -%}
        {{ primary_image | image_url: width: 800 | image_tag:
          loading: card_loading,
          widths: '300, 400, 600, 800',
          sizes: '(max-width: 540px) 50vw, (max-width: 1024px) 33vw, 25vw',
          class: 'product-card__img product-card__img--primary',
          alt: product.featured_image.alt | default: product.title
        }}
        {%- if secondary_image -%}
          {{ secondary_image | image_url: width: 800 | image_tag:
            loading: 'lazy',
            widths: '300, 400, 600, 800',
            sizes: '(max-width: 540px) 50vw, (max-width: 1024px) 33vw, 25vw',
            class: 'product-card__img product-card__img--secondary',
            alt: ''
          }}
        {%- endif -%}
      {%- else -%}
        <div class="product-card__placeholder">
          {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
        </div>
      {%- endif -%}

      <div class="product-card__badges">
        {%- if sold_out -%}
          <span class="product-card__badge product-card__badge--soldout">
            {{ 'product_card.sold_out' | t }}
          </span>
        {%- elsif on_sale -%}
          {%- assign discount_pct = product.compare_at_price | minus: product.price | times: 100.0 | divided_by: product.compare_at_price | round -%}
          <span class="product-card__badge product-card__badge--sale">
            -{{ discount_pct }}%
          </span>
        {%- endif -%}
      </div>
    </div>
  </a>

  <div class="product-card__info">
    {%- if show_type_meta -%}
      {%- if show_vendor and product.vendor != blank -%}
        <span class="product-card__meta">{{ product.vendor }}</span>
      {%- elsif product.type != blank -%}
        <span class="product-card__meta">{{ product.type }}</span>
      {%- endif -%}
    {%- endif -%}

    <a href="{{ product.url }}" class="product-card__title">{{ product.title }}</a>

    <div class="product-card__prices">
      {%- if on_sale -%}
        <span class="product-card__price product-card__price--sale">{{ product.price | money }}</span>
        <span class="product-card__price-compare">{{ product.compare_at_price | money }}</span>
      {%- else -%}
        {%- if product.price_varies -%}
          <span class="product-card__price">
            {{ 'product_card.from_price' | t: price: product.price_min | money }}
          </span>
        {%- else -%}
          <span class="product-card__price">{{ product.price | money }}</span>
        {%- endif -%}
      {%- endif -%}
    </div>
  </div>
</article>

{% stylesheet %}
  .product-card {
    display: flex;
    flex-direction: column;
    gap: 16px;
    width: 100%;
    color: inherit;
  }

  .product-card__media-link {
    display: block;
    color: inherit;
    text-decoration: none;
  }

  .product-card__media {
    position: relative;
    width: 100%;
    overflow: hidden;
    background: var(--color-gray-100);
  }

  .pc-aspect--square    { aspect-ratio: 1 / 1; }
  .pc-aspect--portrait  { aspect-ratio: 3 / 4; }
  .pc-aspect--landscape { aspect-ratio: 4 / 3; }

  .product-card__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: opacity var(--transition-medium), transform var(--transition-smooth);
  }

  .product-card__img--secondary {
    position: absolute;
    inset: 0;
    opacity: 0;
  }

  .product-card:hover .product-card__img--primary { opacity: 0; }
  .product-card:hover .product-card__img--secondary { opacity: 1; }

  .product-card:hover .product-card__img {
    transform: scale(1.03);
  }

  .product-card__placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .product-card__placeholder svg {
    width: 60%;
    opacity: 0.18;
  }

  .product-card__badges {
    position: absolute;
    top: 12px;
    left: 12px;
    display: flex;
    flex-direction: column;
    gap: 6px;
    z-index: 1;
  }

  .product-card__badge {
    display: inline-flex;
    align-items: center;
    padding: 5px 10px;
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .product-card__badge--sale {
    background: var(--color-black);
    color: var(--color-white);
  }

  .product-card__badge--soldout {
    background: var(--color-white);
    color: var(--color-black);
    border: 1px solid var(--color-black);
  }

  .product-card__info {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .product-card__meta {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-gray-500);
  }

  .product-card__title {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 500;
    line-height: 1.3;
    color: var(--color-black);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .product-card__title:hover {
    color: var(--color-gray-600);
  }

  .product-card__prices {
    display: inline-flex;
    align-items: baseline;
    gap: 10px;
    font-family: var(--font-body);
  }

  .product-card__price {
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--color-black);
  }

  .product-card__price--sale {
    color: var(--color-black);
  }

  .product-card__price-compare {
    font-size: var(--text-sm);
    color: var(--color-gray-500);
    text-decoration: line-through;
  }

  @media (max-width: 540px) {
    .product-card__title { font-size: var(--text-base); }
    .product-card { gap: 12px; }
    .product-card__badges { top: 8px; left: 8px; }
    .product-card__badge { padding: 4px 8px; font-size: 0.625rem; }
  }
{% endstylesheet %}
